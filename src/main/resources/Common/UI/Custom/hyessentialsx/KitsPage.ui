$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    @CloseButton = true;
    Anchor: (Width: 860, Height: 660);

    #Title {
      Group {
        $C.@Title { @Text = ""; }

        Label {
          Anchor: (Full: 0);
          Style: (FontSize: 24, TextColor: #f5f7ff, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "Kits";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Horizontal: 14, Top: 2, Bottom: 14);

      Group #HeaderBar {
        Anchor: (Horizontal: 0, Height: 66, Bottom: 10);
        LayoutMode: Left;
        Padding: (Left: 14, Right: 14, Top: 8, Bottom: 8);
        Background: (Color: #191714(0.92));
        OutlineColor: #7d6b3a;
        OutlineSize: 1;

        Group #KitCountRow {
          Anchor: (Width: 220, Height: 48, Right: 12);
          LayoutMode: Top;
          Padding: (Left: 12, Right: 12, Top: 5, Bottom: 5);
          Background: (Color: #2a2318(0.9));

          Label {
            Anchor: (Height: 14);
            Style: (FontSize: 10, TextColor: #b8aa7b, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "AVAILABLE";
          }

          Label #KitCount {
            Text: "0 Kits";
            Anchor: (Height: 24);
            Style: (FontSize: 17, TextColor: #ffd166, RenderBold: true, VerticalAlignment: Center);
          }
        }

        Group #SearchFrame {
          FlexWeight: 1;
          Anchor: (Height: 48);
          LayoutMode: CenterMiddle;
          Padding: (Left: 12, Right: 12, Top: 7, Bottom: 7);
          Background: (Color: #141617(0.84));

          $C.@HeaderSearch #SearchBar {}
        }
      }

      Group #KitListFrame {
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
        Background: (Color: #151515(0.84));
        OutlineColor: #3a3425;
        OutlineSize: 1;

        Group #KitListContainer {
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          FlexWeight: 1;

          Group #KitList {
            LayoutMode: Top;
          }
        }
      }
    }
  }
}

$C.@BackButton {}

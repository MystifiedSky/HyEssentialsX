$E = "EcoCommon.ui";

Group #LeaderboardRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  LayoutMode: Center;

  Group #LeaderboardWindow {
    Anchor: (Width: 760, Height: 540);
    LayoutMode: Top;
    Background: (Color: #0f1726ee);
    Padding: (Top: 10, Bottom: 12, Left: 12, Right: 12);
    OutlineColor: #2f4a72;
    OutlineSize: 1;

    Group #Header {
      LayoutMode: Left;
      Anchor: (Height: 58, Bottom: 8);
      Background: (Color: #15263d);
      Padding: (Left: 12, Right: 10, Top: 6, Bottom: 6);
      OutlineColor: #355986;
      OutlineSize: 1;

      Group {
        LayoutMode: Top;
        FlexWeight: 1;

        Label #Title {
          Text: "Leaderboards";
          Style: (FontSize: 19, TextColor: #f2f7ff, RenderBold: true);
          Anchor: (Bottom: 2);
        }

        Label #Subtitle {
          Text: "Viewing Player Kills";
          Style: (FontSize: 10, TextColor: #8ea9cc, Wrap: true);
          Anchor: (Left: 0, Right: 0);
        }
      }

      TextButton #CloseButton {
        Text: "X";
        Style: $E.@EcoButtonRedStyle;
        Anchor: (Width: 30, Height: 28, Vertical: 0);
      }
    }

    Group #StatButtonsContainer {
      LayoutMode: Top;
      Anchor: (Height: 72, Bottom: 8);
      Background: (Color: #111f34);
      Padding: (Top: 7, Bottom: 2, Left: 8, Right: 8);
      OutlineColor: #2f4a72;
      OutlineSize: 1;

      Group #StatButtons {
        LayoutMode: Top;

        Group {
          LayoutMode: Left;
          Anchor: (Height: 30, Bottom: 4);

          TextButton #StatPlayerKills {
            Text: "Player Kills";
            Style: $E.@EcoButtonStyle;
            Anchor: (Width: 118, Height: 28, Right: 5);
          }
          TextButton #StatMobKills {
            Text: "Mob Kills";
            Style: $E.@EcoButtonStyle;
            Anchor: (Width: 118, Height: 28, Right: 5);
          }
          TextButton #StatDeaths {
            Text: "Deaths";
            Style: $E.@EcoButtonStyle;
            Anchor: (Width: 118, Height: 28, Right: 5);
          }
          TextButton #StatDamageDealt {
            Text: "Damage Dealt";
            Style: $E.@EcoButtonStyle;
            Anchor: (Width: 118, Height: 28, Right: 5);
          }
          TextButton #StatDamageTaken {
            Text: "Damage Taken";
            Style: $E.@EcoButtonStyle;
            Anchor: (Width: 118, Height: 28);
          }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 30);

          TextButton #StatDistance {
            Text: "Distance";
            Style: $E.@EcoButtonStyle;
            Anchor: (Width: 118, Height: 28, Right: 5);
          }
          TextButton #StatMessages {
            Text: "Messages";
            Style: $E.@EcoButtonStyle;
            Anchor: (Width: 118, Height: 28, Right: 5);
          }
          TextButton #StatConnections {
            Text: "Connections";
            Style: $E.@EcoButtonStyle;
            Anchor: (Width: 118, Height: 28, Right: 5);
          }
          TextButton #StatDrops {
            Text: "Drops";
            Style: $E.@EcoButtonStyle;
            Anchor: (Width: 118, Height: 28);
          }
        }
      }
    }

    Group #StatsRow {
      LayoutMode: Left;
      Anchor: (Height: 72, Bottom: 10);

      Group {
        LayoutMode: Top;
        Background: (Color: #111f34);
        FlexWeight: 1;
        Anchor: (Right: 8);
        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
        OutlineColor: #2f4a72;
        OutlineSize: 1;

        Label { Text: "Shown Players"; Style: (FontSize: 10, TextColor: #8ba6ca); }
        Label #PlayerCount { Text: "0"; Style: (FontSize: 21, TextColor: #8fd3ff, RenderBold: true); }
      }

      Group {
        LayoutMode: Top;
        Background: (Color: #111f34);
        FlexWeight: 1;
        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
        OutlineColor: #2f4a72;
        OutlineSize: 1;

        Label { Text: "Shown Total"; Style: (FontSize: 10, TextColor: #8ba6ca); }
        Label #TopTotal { Text: "0"; Style: (FontSize: 21, TextColor: #54e39e, RenderBold: true); }
      }
    }

    Group #ListHeader {
      LayoutMode: Left;
      Anchor: (Height: 28, Bottom: 4);
      Background: (Color: #0b1524);
      Padding: (Left: 10, Right: 10);
      OutlineColor: #2f4a72;
      OutlineSize: 1;

      Label { Text: "Rank"; Style: (FontSize: 11, TextColor: #89a6cb, RenderBold: true); Anchor: (Width: 72, Vertical: 0); }
      Label { Text: "Player"; Style: (FontSize: 11, TextColor: #89a6cb, RenderBold: true); FlexWeight: 1; Anchor: (Vertical: 0); }
      Label #ValueHeader { Text: "Value"; Style: (FontSize: 11, TextColor: #89a6cb, RenderBold: true, HorizontalAlignment: End); Anchor: (Width: 180, Vertical: 0); }
    }

    Group #EntryListContainer {
      LayoutMode: TopScrolling;
      Background: (Color: #111f34);
      FlexWeight: 1;
      Padding: (Top: 8, Bottom: 8, Left: 8, Right: 8);
      OutlineColor: #2f4a72;
      OutlineSize: 1;

      Group #EntryList {
        LayoutMode: Top;
      }
    }

    Group #Footer {
      LayoutMode: Left;
      Anchor: (Height: 24, Top: 8);

      Label #ShowingInfo {
        Text: "Showing 0 players";
        Style: (FontSize: 11, TextColor: #8da8cc);
        FlexWeight: 1;
        Anchor: (Vertical: 0);
      }

      Label {
        Text: "Use /leaderboard category:id for specific item or mob boards";
        Style: (FontSize: 10, TextColor: #6f88ac);
        Anchor: (Vertical: 0);
      }
    }
  }
}

$C = "../Common.ui";

Group {
  Anchor: (Height: 132, Bottom: 10);
  Padding: 10;
  Background: (Color: #181818(0.82));
  OutlineColor: #3a3425;
  OutlineSize: 1;
  LayoutMode: Left;

  Group #PaySection {
    Anchor: (Width: 250, Right: 10);
    LayoutMode: Top;
    Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
    Background: (Color: #241917(0.78));

    Label {
      Anchor: (Height: 18, Bottom: 6);
      Style: (FontSize: 10, TextColor: #ff9f7c, RenderBold: true, RenderUppercase: true, LetterSpacing: 2);
      Text: "PAY";
    }

    Group #PayItems {
      FlexWeight: 1;
      LayoutMode: Top;
    }
  }

  Group #ArrowSection {
    Anchor: (Width: 42, Right: 10);
    LayoutMode: CenterMiddle;

    Label {
      Anchor: (Width: 32, Height: 32);
      Background: (Color: #2a2318(0.9));
      Style: (FontSize: 20, TextColor: #ffd166, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true);
      Text: ">";
    }
  }

  Group #GetSection {
    Anchor: (Width: 250, Right: 12);
    LayoutMode: Top;
    Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
    Background: (Color: #14211b(0.78));

    Label {
      Anchor: (Height: 18, Bottom: 6);
      Style: (FontSize: 10, TextColor: #7ee0a8, RenderBold: true, RenderUppercase: true, LetterSpacing: 2);
      Text: "GET";
    }

    Group #GetItems {
      FlexWeight: 1;
      LayoutMode: Top;
    }
  }

  Group #ActionSection {
    FlexWeight: 1;
    LayoutMode: Top;
    Padding: (Left: 4, Right: 4, Top: 8, Bottom: 8);

    Group #StatusPill {
      Anchor: (Horizontal: 0, Height: 28, Bottom: 8);
      Background: (Color: #111417(0.9));

      Label #StatusLabel {
        Anchor: (Full: 0);
        Style: (FontSize: 11, TextColor: #66ff66, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
        Text: "";
      }
    }

    Group #QuickQuantityButtons {
      Anchor: (Horizontal: 0, Height: 30, Bottom: 8);
      LayoutMode: Left;

      Button #TradeOneButton {
        FlexWeight: 1;
        Anchor: (Height: 30, Right: 6);
        Background: (Color: #263544);
        Style: (
          Hovered: (Background: #34495f),
          Pressed: (Background: #1d2a36)
        );

        Label {
          Text: "x1";
          Style: (FontSize: 12, TextColor: #e8f0f8, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true);
        }
      }

      Button #TradeTenButton {
        FlexWeight: 1;
        Anchor: (Height: 30, Right: 6);
        Background: (Color: #263544);
        Style: (
          Hovered: (Background: #34495f),
          Pressed: (Background: #1d2a36)
        );

        Label {
          Text: "x10";
          Style: (FontSize: 12, TextColor: #e8f0f8, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true);
        }
      }

      Button #TradeHundredButton {
        FlexWeight: 1;
        Anchor: (Height: 30);
        Background: (Color: #263544);
        Style: (
          Hovered: (Background: #34495f),
          Pressed: (Background: #1d2a36)
        );

        Label {
          Text: "x100";
          Style: (FontSize: 11, TextColor: #e8f0f8, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true);
        }
      }
    }

    $C.@TextButton #TradeButton {
      Text: "Trade";
      Anchor: (Horizontal: 0, Height: 38);
      TooltipText: "Execute this trade";
    }
  }
}

$E = "EcoCommon.ui";

Group #AdminRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  LayoutMode: Center;

  Group #AdminShell {
    Anchor: (Width: 980, Height: 620);
    LayoutMode: Left;
    Background: (Color: #0e1727ef);
    OutlineColor: #2f4a72;
    OutlineSize: 1;

    Group #Sidebar {
      LayoutMode: Top;
      Background: (Color: #111f34);
      Anchor: (Width: 198, Top: 0, Bottom: 0);
      Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);
      OutlineColor: #2f4a72;
      OutlineSize: 1;

      Group #BrandBlock {
        LayoutMode: Top;
        Background: (Color: #173055);
        Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);
        Anchor: (Height: 96, Bottom: 12);
        OutlineColor: #3a6498;
        OutlineSize: 1;

        Label #Title {
          Text: "HyEssentialsX Economy Admin Panel";
          Style: (FontSize: 12, TextColor: #f2f7ff, RenderBold: true, Wrap: true);
          Anchor: (Left: 0, Right: 0, Height: 32, Bottom: 4);
        }

        Label {
          Text: "Control balances, logs, and HUD settings";
          Style: (FontSize: 10, TextColor: #9ab6d9, Wrap: true);
          Anchor: (Left: 0, Right: 0);
        }
      }

      TextButton #TabDashboard {
        Text: "Dashboard";
        Style: $E.@EcoButtonStyle;
        Anchor: (Height: 34, Bottom: 6);
      }

      TextButton #TabPlayers {
        Text: "Players";
        Style: $E.@EcoButtonStyle;
        Anchor: (Height: 34, Bottom: 6);
      }

      TextButton #TabTop {
        Text: "Top";
        Style: $E.@EcoButtonStyle;
        Anchor: (Height: 34, Bottom: 6);
      }

      TextButton #TabLog {
        Text: "Log";
        Style: $E.@EcoButtonStyle;
        Anchor: (Height: 34, Bottom: 6);
      }

      TextButton #TabConfig {
        Text: "Config";
        Style: $E.@EcoButtonStyle;
        Anchor: (Height: 34, Bottom: 12);
      }

      Group { FlexWeight: 1; }

      TextButton #ForceSaveButton {
        Text: "Force Save";
        Style: $E.@EcoButtonAccentStyle;
        Anchor: (Height: 34, Bottom: 8);
      }

      TextButton #CloseButton {
        Text: "Close";
        Style: $E.@EcoButtonRedStyle;
        Anchor: (Height: 34);
      }
    }

    Group #Workspace {
      LayoutMode: Top;
      FlexWeight: 1;
      Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);

      Group #WorkspaceHeader {
        LayoutMode: Left;
        Background: (Color: #111f34);
        Anchor: (Height: 52, Bottom: 10);
        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
        OutlineColor: #2f4a72;
        OutlineSize: 1;

        Label {
          Text: "Economy Operations";
          Style: (FontSize: 16, TextColor: #f2f7ff, RenderBold: true);
          FlexWeight: 1;
          Anchor: (Vertical: 0);
        }

        Label {
          Text: "Realtime management panel";
          Style: (FontSize: 11, TextColor: #8ca7cc);
          Anchor: (Vertical: 0);
        }
      }

      Group #DashboardContent {
        LayoutMode: Top;
        FlexWeight: 1;

        Group #StatsRow {
          LayoutMode: Left;
          Anchor: (Height: 88, Bottom: 10);

          Group {
            LayoutMode: Top;
            Background: (Color: #111f34);
            FlexWeight: 1;
            Anchor: (Right: 8);
            Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Label { Text: "Total Circulating"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #TotalCirculating { Text: "$0"; Style: (FontSize: 22, TextColor: #54e39e, RenderBold: true); }
          }

          Group {
            LayoutMode: Top;
            Background: (Color: #111f34);
            FlexWeight: 1;
            Anchor: (Right: 8);
            Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Label { Text: "Players with Balance"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #TotalPlayers { Text: "0"; Style: (FontSize: 22, TextColor: #8fd3ff, RenderBold: true); }
          }

          Group {
            LayoutMode: Top;
            Background: (Color: #111f34);
            FlexWeight: 1;
            Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Label { Text: "Average Balance"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #AverageBalance { Text: "$0"; Style: (FontSize: 22, TextColor: #f2be5c, RenderBold: true); }
          }
        }

        Group #ConfigInfo {
          LayoutMode: Top;
          Background: (Color: #111f34);
          Anchor: (Height: 74, Bottom: 10);
          Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Label {
            Text: "Current Economy Config";
            Style: (FontSize: 12, TextColor: #d7e7ff, RenderBold: true);
            Anchor: (Bottom: 6);
          }

          Label #ConfigSummary {
            Text: "";
            Style: (FontSize: 11, TextColor: #a7c2e6);
          }
        }

        Group #ActivityLogSection {
          LayoutMode: Top;
          Background: (Color: #111f34);
          FlexWeight: 1;
          Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Label {
            Text: "Recent Activity";
            Style: (FontSize: 12, TextColor: #d7e7ff, RenderBold: true);
            Anchor: (Bottom: 8);
          }

          Group #ActivityLogContainer {
            LayoutMode: TopScrolling;
            FlexWeight: 1;

            Group #ActivityLog {
              LayoutMode: Top;
            }
          }
        }
      }

      Group #PlayersContent {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;

        Group {
          LayoutMode: Left;
          Anchor: (Height: 36, Bottom: 8);

          Label {
            Text: "Search:";
            Style: (FontSize: 11, TextColor: #9ab6d9);
            Anchor: (Width: 54, Vertical: 0);
          }

          Group {
            Background: (Color: #0b1524);
            Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
            FlexWeight: 1;
            Anchor: (Height: 30);
            OutlineColor: #355986;
            OutlineSize: 1;

            TextField #PlayerSearch {
              Style: (FontSize: 13, TextColor: #f0f5ff);
              FlexWeight: 1;
            }
          }
        }

        Group #PlayerListContainer {
          LayoutMode: TopScrolling;
          Background: (Color: #111f34);
          FlexWeight: 1;
          Padding: (Top: 8, Bottom: 8, Left: 8, Right: 8);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Group #PlayerList { LayoutMode: Top; }
        }

        Group {
          LayoutMode: Left;
          Background: (Color: #111f34);
          Anchor: (Height: 56, Top: 8, Bottom: 8);
          Padding: (Top: 8, Bottom: 8, Left: 10, Right: 10);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Group {
            LayoutMode: Top;
            FlexWeight: 1;
            Anchor: (Vertical: 0);

            Label #SelectedLabel { Text: "Select a player"; Style: (FontSize: 10, TextColor: #89a6cb); }
            Label #SelectedName { Text: ""; Style: (FontSize: 13, TextColor: #f2f7ff, RenderBold: true); }
          }

          Label {
            Text: "Amount";
            Style: (FontSize: 11, TextColor: #9ab6d9);
            Anchor: (Vertical: 0, Right: 8);
          }

          Group {
            Background: (Color: #0b1524);
            Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
            Anchor: (Width: 110, Height: 30, Vertical: 0, Right: 10);
            OutlineColor: #355986;
            OutlineSize: 1;

            TextField #ActionAmount {
              Style: (FontSize: 13, TextColor: #f0f5ff);
              FlexWeight: 1;
            }
          }

          TextButton #GiveButton { Text: "GIVE"; Style: $E.@EcoButtonGreenStyle; Anchor: (Width: 58, Height: 30, Vertical: 0, Right: 6); }
          TextButton #TakeButton { Text: "TAKE"; Style: $E.@EcoButtonRedStyle; Anchor: (Width: 58, Height: 30, Vertical: 0, Right: 6); }
          TextButton #SetButton { Text: "SET"; Style: $E.@EcoButtonStyle; Anchor: (Width: 52, Height: 30, Vertical: 0, Right: 6); }
          TextButton #ResetButton { Text: "RESET"; Style: $E.@EcoButtonStyle; Anchor: (Width: 66, Height: 30, Vertical: 0); }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 28);

          TextButton #PrevPageButton { Text: "< Prev"; Style: $E.@EcoButtonStyle; Anchor: (Width: 70, Height: 24, Vertical: 0); }
          Label #PageInfo { Text: "Page 1/1"; Style: (FontSize: 11, TextColor: #8da8cc, HorizontalAlignment: Center); FlexWeight: 1; Anchor: (Vertical: 0); }
          TextButton #NextPageButton { Text: "Next >"; Style: $E.@EcoButtonStyle; Anchor: (Width: 70, Height: 24, Vertical: 0); }
        }
      }

      Group #TopContent {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;

        Label {
          Text: "Top 10 Balances";
          Style: (FontSize: 14, TextColor: #f2f7ff, RenderBold: true);
          Anchor: (Bottom: 8);
        }

        Group #TopListContainer {
          LayoutMode: TopScrolling;
          Background: (Color: #111f34);
          FlexWeight: 1;
          Padding: (Top: 8, Bottom: 8, Left: 8, Right: 8);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Group #TopList { LayoutMode: Top; }
        }
      }

      Group #LogContent {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;

        Group {
          LayoutMode: Left;
          Anchor: (Height: 36, Bottom: 8);

          Label {
            Text: "Filter:";
            Style: (FontSize: 11, TextColor: #9ab6d9);
            Anchor: (Width: 46, Vertical: 0);
          }

          Group {
            Background: (Color: #0b1524);
            Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
            Anchor: (Width: 220, Height: 30, Right: 12);
            OutlineColor: #355986;
            OutlineSize: 1;

            TextField #LogFilter {
              Style: (FontSize: 12, TextColor: #f0f5ff);
              FlexWeight: 1;
            }
          }

          Label #LogCountInfo {
            Text: "Entries: 0";
            Style: (FontSize: 11, TextColor: #8da8cc);
            FlexWeight: 1;
            Anchor: (Vertical: 0);
          }
        }

        Group #LogListContainer {
          LayoutMode: TopScrolling;
          Background: (Color: #111f34);
          FlexWeight: 1;
          Padding: (Top: 8, Bottom: 8, Left: 8, Right: 8);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Group #LogList { LayoutMode: Top; }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 28, Top: 8);

          TextButton #LogPrevButton { Text: "< Prev"; Style: $E.@EcoButtonStyle; Anchor: (Width: 70, Height: 24, Vertical: 0); }
          Label #LogPageInfo { Text: "Page 1/1"; Style: (FontSize: 11, TextColor: #8da8cc, HorizontalAlignment: Center); FlexWeight: 1; Anchor: (Vertical: 0); }
          TextButton #LogNextButton { Text: "Next >"; Style: $E.@EcoButtonStyle; Anchor: (Width: 70, Height: 24, Vertical: 0); }
        }
      }

      Group #ConfigContent {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;

        Group {
          LayoutMode: Left;
          Anchor: (Height: 36, Bottom: 10);

          TextButton #ReloadConfigButton { Text: "Reload"; Style: $E.@EcoButtonStyle; Anchor: (Width: 90, Height: 30); }
          TextButton #SaveConfigButton { Text: "Save"; Style: $E.@EcoButtonAccentStyle; Anchor: (Width: 90, Height: 30, Left: 8); }
          TextButton #ResetDefaultsButton { Text: "Reset"; Style: $E.@EcoButtonRedStyle; Anchor: (Width: 90, Height: 30, Left: 8); }

          Label #ConfigStatus {
            Text: "";
            Style: (FontSize: 12, TextColor: #8da8cc);
            Anchor: (Vertical: 0, Left: 12);
          }
        }

        Group #ConfigForm {
          LayoutMode: Top;
          Background: (Color: #111f34);
          FlexWeight: 1;
          Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "Currency Symbol"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 130, Vertical: 0); }
            Group {
              Background: (Color: #0b1524);
              Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
              Anchor: (Width: 120, Height: 30, Vertical: 0);
              OutlineColor: #355986;
              OutlineSize: 1;
              TextField #CurrencySymbolInput { Style: (FontSize: 13, TextColor: #f0f5ff); FlexWeight: 1; }
            }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "Starting Balance"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 130, Vertical: 0); }
            Group {
              Background: (Color: #0b1524);
              Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
              Anchor: (Width: 160, Height: 30, Vertical: 0);
              OutlineColor: #355986;
              OutlineSize: 1;
              TextField #StartingBalanceInput { Style: (FontSize: 13, TextColor: #f0f5ff); FlexWeight: 1; }
            }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "HUD Label"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 130, Vertical: 0); }
            Group {
              Background: (Color: #0b1524);
              Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
              Anchor: (Width: 240, Height: 30, Vertical: 0);
              OutlineColor: #355986;
              OutlineSize: 1;
              TextField #HudLabelInput { Style: (FontSize: 13, TextColor: #f0f5ff); FlexWeight: 1; }
            }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 10);
            Label { Text: "HUD Interval (ms)"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 130, Vertical: 0); }
            Group {
              Background: (Color: #0b1524);
              Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
              Anchor: (Width: 160, Height: 30, Vertical: 0);
              OutlineColor: #355986;
              OutlineSize: 1;
              TextField #HudIntervalInput { Style: (FontSize: 13, TextColor: #f0f5ff); FlexWeight: 1; }
            }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "HUD Enabled"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 130, Vertical: 0); }
            TextButton #HudToggle { Text: "ON"; Style: $E.@EcoButtonStyle; Anchor: (Width: 92, Height: 28, Vertical: 0); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "HUD Default Hidden"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 130, Vertical: 0); }
            TextButton #HudDefaultHiddenToggle { Text: "OFF"; Style: $E.@EcoButtonStyle; Anchor: (Width: 92, Height: 28, Vertical: 0); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34);
            Label { Text: "HUD Anchor"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 130, Vertical: 0); }
            TextButton #HudAnchorToggle { Text: "BOTTOM RIGHT"; Style: $E.@EcoButtonStyle; Anchor: (Width: 170, Height: 28, Vertical: 0); }
          }
        }
      }
    }
  }
}

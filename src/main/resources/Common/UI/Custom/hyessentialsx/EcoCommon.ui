@EcoButtonLabelStyle = LabelStyle(
  FontSize: 11,
  TextColor: #e9f1ff,
  RenderBold: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

@EcoButtonLabelUpperStyle = LabelStyle(
  FontSize: 11,
  TextColor: #e9f1ff,
  RenderBold: true,
  RenderUppercase: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

@EcoButtonStyle = TextButtonStyle(
  Default: (Background: (Color: #263544), LabelStyle: @EcoButtonLabelUpperStyle),
  Hovered: (Background: (Color: #34495f), LabelStyle: @EcoButtonLabelUpperStyle),
  Pressed: (Background: (Color: #1d2a36), LabelStyle: @EcoButtonLabelUpperStyle),
  Disabled: (Background: (Color: #2a2f3a), LabelStyle: @EcoButtonLabelUpperStyle)
);

@EcoButtonGreenStyle = TextButtonStyle(
  Default: (Background: (Color: #1d6f4a), LabelStyle: @EcoButtonLabelUpperStyle),
  Hovered: (Background: (Color: #29875e), LabelStyle: @EcoButtonLabelUpperStyle),
  Pressed: (Background: (Color: #16583b), LabelStyle: @EcoButtonLabelUpperStyle),
  Disabled: (Background: (Color: #2a2f3a), LabelStyle: @EcoButtonLabelUpperStyle)
);

@EcoButtonRedStyle = TextButtonStyle(
  Default: (Background: (Color: #7c3742), LabelStyle: @EcoButtonLabelUpperStyle),
  Hovered: (Background: (Color: #a04a59), LabelStyle: @EcoButtonLabelUpperStyle),
  Pressed: (Background: (Color: #612a33), LabelStyle: @EcoButtonLabelUpperStyle),
  Disabled: (Background: (Color: #2a2f3a), LabelStyle: @EcoButtonLabelUpperStyle)
);

@EcoButtonAccentStyle = TextButtonStyle(
  Default: (Background: (Color: #7d6b3a), LabelStyle: @EcoButtonLabelUpperStyle),
  Hovered: (Background: (Color: #9a8549), LabelStyle: @EcoButtonLabelUpperStyle),
  Pressed: (Background: (Color: #5f512c), LabelStyle: @EcoButtonLabelUpperStyle),
  Disabled: (Background: (Color: #2a2f3a), LabelStyle: @EcoButtonLabelUpperStyle)
);

$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 760, Height: 620);

    #Title {
      Group {
        $C.@Title { @Text = ""; }

        Label {
          Anchor: (Full: 0);
          Style: (FontSize: 24, TextColor: #f5f7ff, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "Your Homes";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Horizontal: 14, Top: 2, Bottom: 14);

      Group #HomeHeader {
        Anchor: (Horizontal: 0, Height: 66, Bottom: 10);
        LayoutMode: Left;
        Padding: (Left: 14, Right: 14, Top: 8, Bottom: 8);
        Background: (Color: #191714(0.92));
        OutlineColor: #7d6b3a;
        OutlineSize: 1;

        Group {
          FlexWeight: 1;
          Anchor: (Height: 48, Right: 12);
          LayoutMode: Top;
          Padding: (Left: 12, Right: 12, Top: 5, Bottom: 5);
          Background: (Color: #141617(0.84));

          Label {
            Anchor: (Height: 14);
            Style: (FontSize: 10, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "SAVED LOCATIONS";
          }

          Label #HomeCount {
            Text: "0 Homes";
            Anchor: (Height: 24);
            Style: (FontSize: 17, TextColor: #ffd166, RenderBold: true, VerticalAlignment: Center);
          }
        }

        $C.@TextButton #CloseButton {
          Anchor: (Width: 98, Height: 34, Vertical: 0);
          Text: "Close";
        }
      }

      Group #HomesListFrame {
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
        Background: (Color: #151515(0.84));
        OutlineColor: #3a3425;
        OutlineSize: 1;

        Group #HomesListContainer {
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          FlexWeight: 1;

          Group #HomesList {
            LayoutMode: Top;
          }
        }
      }
    }
  }
}

$C.@BackButton {}

$C = "../Common.ui";

$C.@PageOverlay {

  $C.@DecoratedContainer {
    Anchor: (Width: 850, Height: 650);

    #Title {
      Group {
        $C.@Title {
          @Text = "Shop";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 15, Right: 15, Top: 5, Bottom: 10);

      Group #ShopHeader {
        Anchor: (Height: 35, Bottom: 5);
        LayoutMode: Left;

        Label #ShopTitle {
          FlexWeight: 1;
          Style: (FontSize: 18, TextColor: #93844c, RenderBold: true);
          Text: "";
        }

        Label #ShopFunds {
          Anchor: (Width: 220);
          Style: (FontSize: 12, TextColor: #aaaaaa, HorizontalAlignment: Center);
          Text: "";
          Visible: false;
        }
      }

      Group {
        Anchor: (Height: 1, Bottom: 10);
        Background: (Color: #93844c(0.4));
      }

      Group #TradeSection {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Visible: true;

        Label #NoTradesLabel {
          Anchor: (Height: 60);
          Style: (FontSize: 15, TextColor: #666666, HorizontalAlignment: Center);
          Text: "This shop has no trades available";
          Visible: false;
        }

        Group #TradeCards {
          LayoutMode: Top;
          Padding: (Right: 10);
        }
      }

      Group #Pager {
        Anchor: (Height: 32, Top: 6);
        LayoutMode: Left;

        Group { FlexWeight: 1; }

        $C.@TextButton #PrevPage {
          Anchor: (Width: 40, Height: 28);
          Text: "<";
        }

        Label #PageInfo {
          Anchor: (Width: 140);
          Style: (FontSize: 12, TextColor: #888888, HorizontalAlignment: Center);
          Text: "Page 1/1";
        }

        $C.@TextButton #NextPage {
          Anchor: (Width: 40, Height: 28);
          Text: ">";
        }

        Group { FlexWeight: 1; }
      }
    }
  }
}

$C.@BackButton {}

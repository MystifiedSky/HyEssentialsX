$C = "../Common.ui";

$C.@PageOverlay {
  $C.@Container {
    @CloseButton = true;
    Anchor: (Width: 640, Height: 560);

    #Title {
      $C.@Title {
        @Text = "Server Rules";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 16, Right: 16, Top: 8, Bottom: 8);

      Group #HeaderRow {
        Anchor: (Height: 26, Bottom: 6);
        LayoutMode: Left;

        Label #RuleCount {
          Text: "0 Rules";
          Style: (FontSize: 12, TextColor: #aaaaaa);
          Anchor: (Vertical: 0);
        }

        Group { FlexWeight: 1; }

        Label #RangeInfo {
          Text: "Showing 0-0 of 0";
          Style: (FontSize: 12, TextColor: #888888);
          Anchor: (Vertical: 0);
        }
      }

      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #93844c(0.35));
      }

      Group #RuleListFrame {
        LayoutMode: Top;
        FlexWeight: 1;
        Background: (Color: #0a0a0a(0.38));
        Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);

        Group #RuleListContainer {
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          FlexWeight: 1;

          Group #RuleList {
            LayoutMode: Top;
          }
        }
      }

      Group #FooterRow {
        Anchor: (Height: 34, Top: 10);
        LayoutMode: Left;

        Group { FlexWeight: 1; }

        $C.@TextButton #PrevButton {
          Anchor: (Width: 92, Height: 28, Vertical: 0, Right: 6);
          Text: "< Prev";
        }

        Label #PageInfo {
          Text: "Page 1/1";
          Style: (FontSize: 12, TextColor: #aaaaaa, HorizontalAlignment: Center);
          Anchor: (Width: 130, Vertical: 0, Right: 6);
        }

        $C.@TextButton #NextButton {
          Anchor: (Width: 92, Height: 28, Vertical: 0);
          Text: "Next >";
        }
      }
    }
  }
}

$C.@BackButton {}

Group #StatsItemRow {
  LayoutMode: Left;
  Background: (Color: #16283f);
  Padding: (Top: 7, Bottom: 7, Left: 10, Right: 10);
  Anchor: (Left: 0, Right: 0, Height: 58, Bottom: 5);
  OutlineColor: #2f4f78;
  OutlineSize: 1;

  Group #IconFrame {
    Anchor: (Width: 40, Height: 40, Vertical: 0, Right: 10);
    Background: (Color: #0b1524);
    OutlineColor: #2f4f78;
    OutlineSize: 1;

    ItemIcon #ItemIcon {
      Anchor: (Width: 34, Height: 34, Left: 3, Top: 3);
    }

    Label #IconFallback {
      Text: "?";
      Style: (FontSize: 16, TextColor: #8fd3ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
      Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
      Visible: true;
    }
  }

  Group {
    LayoutMode: Top;
    FlexWeight: 1;
    Anchor: (Vertical: 0);

    Label #ItemName {
      Text: "Item";
      Style: (FontSize: 14, TextColor: #f4f8ff, RenderBold: true);
      Anchor: (Bottom: 2);
    }

    Label #ItemDetails {
      Text: "Mined 0   Placed 0   Crafted 0   Picked Up 0   Dropped 0";
      Style: (FontSize: 11, TextColor: #8da8cc);
      Anchor: (Left: 0, Right: 0);
    }
  }
}

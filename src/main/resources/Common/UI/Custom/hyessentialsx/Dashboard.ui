$E = "EcoCommon.ui";

@CommandButtonLabel = LabelStyle(
  FontSize: 11,
  TextColor: #e9f1ff,
  RenderBold: true,
  RenderUppercase: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

@CommandButton = TextButtonStyle(
  Default: (Background: (Color: #263544), LabelStyle: @CommandButtonLabel),
  Hovered: (Background: (Color: #34495f), LabelStyle: @CommandButtonLabel),
  Pressed: (Background: (Color: #1d2a36), LabelStyle: @CommandButtonLabel),
  Disabled: (Background: (Color: #2a2f3a), LabelStyle: @CommandButtonLabel)
);

@CommandButtonGreen = TextButtonStyle(
  Default: (Background: (Color: #1d6f4a), LabelStyle: @CommandButtonLabel),
  Hovered: (Background: (Color: #29875e), LabelStyle: @CommandButtonLabel),
  Pressed: (Background: (Color: #16583b), LabelStyle: @CommandButtonLabel),
  Disabled: (Background: (Color: #2a2f3a), LabelStyle: @CommandButtonLabel)
);

@CommandButtonRed = TextButtonStyle(
  Default: (Background: (Color: #7c3742), LabelStyle: @CommandButtonLabel),
  Hovered: (Background: (Color: #a04a59), LabelStyle: @CommandButtonLabel),
  Pressed: (Background: (Color: #612a33), LabelStyle: @CommandButtonLabel),
  Disabled: (Background: (Color: #2a2f3a), LabelStyle: @CommandButtonLabel)
);

@CommandButtonGold = TextButtonStyle(
  Default: (Background: (Color: #7d6b3a), LabelStyle: @CommandButtonLabel),
  Hovered: (Background: (Color: #9a8549), LabelStyle: @CommandButtonLabel),
  Pressed: (Background: (Color: #5f512c), LabelStyle: @CommandButtonLabel),
  Disabled: (Background: (Color: #2a2f3a), LabelStyle: @CommandButtonLabel)
);

Group #CommandCenterRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  LayoutMode: Center;

  Group #CommandCenterShell {
    Anchor: (Width: 1280, Height: 900);
    LayoutMode: Left;
    Background: (Color: #0e1727ef);
    OutlineColor: #2f4a72;
    OutlineSize: 1;

    Group #Sidebar {
      LayoutMode: Top;
      Background: (Color: #111f34);
      Anchor: (Width: 210, Top: 0, Bottom: 0);
      Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);
      OutlineColor: #2f4a72;
      OutlineSize: 1;

      Group #BrandBlock {
        LayoutMode: Top;
        Background: (Color: #173055);
        Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);
        Anchor: (Height: 116, Bottom: 12);
        OutlineColor: #3a6498;
        OutlineSize: 1;

        Label {
          Text: "HyEssentialsX Command Center";
          Style: (FontSize: 13, TextColor: #f2f7ff, RenderBold: true, Wrap: true);
          Anchor: (Left: 0, Right: 0, Height: 38, Bottom: 4);
        }

        Label {
          Text: "Staff operations, live status, and admin launchpad";
          Style: (FontSize: 10, TextColor: #9ab6d9, Wrap: true);
          Anchor: (Left: 0, Right: 0, Height: 42);
        }

        Label #VersionText {
          Text: "vunknown";
          Style: (FontSize: 10, TextColor: #d5c47d, RenderBold: true);
          Anchor: (Left: 0, Right: 0);
        }
      }

      TextButton #TabOverview { Text: "OVERVIEW"; Style: @CommandButton; Anchor: (Height: 34, Bottom: 6); }
      TextButton #TabPlayers { Text: "PLAYERS"; Style: @CommandButton; Anchor: (Height: 34, Bottom: 6); }
      TextButton #TabModeration { Text: "MODERATION"; Style: @CommandButton; Anchor: (Height: 34, Bottom: 6); }
      TextButton #TabSystems { Text: "SYSTEMS"; Style: @CommandButton; Anchor: (Height: 34, Bottom: 6); }
      TextButton #TabLaunch { Text: "LAUNCH"; Style: @CommandButton; Anchor: (Height: 34, Bottom: 12); }

      Group { FlexWeight: 1; }

      TextButton #RefreshButton {
        Text: "Refresh";
        Style: @CommandButtonGold;
        Anchor: (Height: 34, Bottom: 8);
      }

      TextButton #CloseButton {
        Text: "Close";
        Style: @CommandButtonRed;
        Anchor: (Height: 34);
      }
    }

    Group #Workspace {
      LayoutMode: Top;
      FlexWeight: 1;
      Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);

      Group #Header {
        LayoutMode: Left;
        Background: (Color: #111f34);
        Anchor: (Height: 54, Bottom: 10);
        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
        OutlineColor: #2f4a72;
        OutlineSize: 1;

        Label {
          Text: "Staff Operations";
          Style: (FontSize: 16, TextColor: #f2f7ff, RenderBold: true);
          Anchor: (Width: 210, Vertical: 0);
        }

        Label #StatusText {
          Text: "Ready.";
          Style: (FontSize: 12, TextColor: #8fb6e8, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
          FlexWeight: 1;
          Anchor: (Vertical: 0);
        }
      }

      Group #OverviewContent {
        LayoutMode: Top;
        FlexWeight: 1;

        Group #StatsRow {
          LayoutMode: Left;
          Anchor: (Height: 94, Bottom: 10);

          Group { LayoutMode: Top; Background: (Color: #111f34); FlexWeight: 1; Anchor: (Right: 8); Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10); OutlineColor: #2f4a72; OutlineSize: 1;
            Label { Text: "ONLINE"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #OnlineValue { Text: "0"; Style: (FontSize: 24, TextColor: #8fd3ff, RenderBold: true); }
          }
          Group { LayoutMode: Top; Background: (Color: #111f34); FlexWeight: 1; Anchor: (Right: 8); Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10); OutlineColor: #2f4a72; OutlineSize: 1;
            Label { Text: "TRACKED"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #TrackedValue { Text: "0"; Style: (FontSize: 24, TextColor: #54e39e, RenderBold: true); }
          }
          Group { LayoutMode: Top; Background: (Color: #111f34); FlexWeight: 1; Anchor: (Right: 8); Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10); OutlineColor: #2f4a72; OutlineSize: 1;
            Label { Text: "MODERATION"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #ModerationValue { Text: "0"; Style: (FontSize: 24, TextColor: #ff9f82, RenderBold: true); }
          }
          Group { LayoutMode: Top; Background: (Color: #111f34); FlexWeight: 1; Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10); OutlineColor: #2f4a72; OutlineSize: 1;
            Label { Text: "MARKET"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #MarketValue { Text: "0"; Style: (FontSize: 24, TextColor: #d5c47d, RenderBold: true); }
          }
        }

        Group #InsightPanel {
          LayoutMode: Top;
          Background: (Color: #111f34);
          FlexWeight: 1;
          Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Label {
            Text: "Operational Snapshot";
            Style: (FontSize: 13, TextColor: #d7e7ff, RenderBold: true);
            Anchor: (Height: 24, Bottom: 8);
          }

          Group #InsightList {
            LayoutMode: Top;
            FlexWeight: 1;
          }
        }
      }

      Group #PlayersContent {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;

        Group {
          LayoutMode: Left;
          Anchor: (Height: 38, Bottom: 8);

          Label {
            Text: "Search";
            Style: (FontSize: 11, TextColor: #9ab6d9, RenderBold: true);
            Anchor: (Width: 60, Vertical: 0);
          }

          Group {
            Background: (Color: #0b1524);
            Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
            FlexWeight: 1;
            Anchor: (Height: 30, Right: 10);
            OutlineColor: #355986;
            OutlineSize: 1;

            TextField #PlayerSearch {
              Style: (FontSize: 13, TextColor: #f0f5ff);
              FlexWeight: 1;
            }
          }

          Label #PlayerPageInfo {
            Text: "Page 1/1";
            Style: (FontSize: 11, TextColor: #8da8cc);
            Anchor: (Width: 170, Vertical: 0);
          }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 30, Bottom: 8);
          TextButton #FilterAllButton { Text: "All"; Style: @CommandButton; Anchor: (Width: 64, Right: 5); }
          TextButton #FilterOnlineButton { Text: "Online"; Style: @CommandButton; Anchor: (Width: 82, Right: 5); }
          TextButton #FilterPunishedButton { Text: "Punished"; Style: @CommandButton; Anchor: (Width: 98, Right: 5); }
          TextButton #FilterWarnedButton { Text: "Warned"; Style: @CommandButton; Anchor: (Width: 88, Right: 5); }
          TextButton #FilterBalanceButton { Text: "Balance"; Style: @CommandButton; Anchor: (Width: 92, Right: 5); }
          TextButton #FilterNewButton { Text: "New"; Style: @CommandButton; Anchor: (Width: 66, Right: 10); }
          TextButton #SortButton { Text: "Sort: Name"; Style: @CommandButtonGold; Anchor: (Width: 132); }
          Label { Text: ""; FlexWeight: 1; }
        }

        Group {
          LayoutMode: Left;
          FlexWeight: 1;

          Group #PlayerBrowser {
            LayoutMode: Top;
            FlexWeight: 1;
            Anchor: (Right: 10);
            Background: (Color: #111f34);
            Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Group #PlayerListHeader {
              LayoutMode: Left;
              Anchor: (Height: 24, Bottom: 6);
              Label { Text: "Player"; FlexWeight: 1; Style: (FontSize: 10, TextColor: #8ba6ca, RenderBold: true); }
              Label { Text: "State"; Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8ba6ca, RenderBold: true); }
              Label { Text: "Balance"; Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8ba6ca, RenderBold: true); }
              Label { Text: "Playtime"; Anchor: (Width: 95); Style: (FontSize: 10, TextColor: #8ba6ca, RenderBold: true); }
              Label { Text: ""; Anchor: (Width: 58); }
            }

            Group #PlayerListContainer {
              LayoutMode: TopScrolling;
              FlexWeight: 1;
              Group #PlayerList { LayoutMode: Top; }
            }

            Group #PlayerPager {
              LayoutMode: Left;
              Anchor: (Height: 34, Top: 8);
              TextButton #PlayerPrevButton { Text: "< Prev"; Style: @CommandButton; Anchor: (Width: 90, Height: 30); }
              Label { Text: ""; FlexWeight: 1; }
              TextButton #PlayerNextButton { Text: "Next >"; Style: @CommandButton; Anchor: (Width: 90, Height: 30); }
            }
          }

          Group #SelectedPanel {
            LayoutMode: Top;
            Anchor: (Width: 430);
            Background: (Color: #111f34);
            Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Label #SelectedName {
              Text: "No player selected";
              Anchor: (Height: 28, Bottom: 4);
              Style: (FontSize: 15, TextColor: #f2f7ff, RenderBold: true, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9);
            }

            Label #SelectedMeta {
              Text: "";
              Anchor: (Height: 42, Bottom: 8);
              Style: (FontSize: 10, TextColor: #8da8cc, Wrap: true);
            }

            Group #RiskFlagListContainer {
              LayoutMode: TopScrolling;
              Anchor: (Height: 54, Bottom: 8);
              Padding: (Top: 5, Bottom: 5, Left: 6, Right: 6);
              Background: (Color: #0b1524);
              OutlineColor: #355986;
              OutlineSize: 1;
              Group #RiskFlagList { LayoutMode: Top; }
            }

            Group { LayoutMode: Left; Anchor: (Height: 30, Bottom: 6);
              TextButton #ProfileTabOverview { Text: "Overview"; Style: @CommandButton; FlexWeight: 1; Anchor: (Right: 5); }
              TextButton #ProfileTabPunishments { Text: "Punish"; Style: @CommandButton; FlexWeight: 1; Anchor: (Right: 5); }
              TextButton #ProfileTabEconomy { Text: "Economy"; Style: @CommandButton; FlexWeight: 1; }
            }

            Group { LayoutMode: Left; Anchor: (Height: 30, Bottom: 8);
              TextButton #ProfileTabTravel { Text: "Travel"; Style: @CommandButton; FlexWeight: 1; Anchor: (Right: 5); }
              TextButton #ProfileTabStats { Text: "Stats"; Style: @CommandButton; FlexWeight: 1; Anchor: (Right: 5); }
              TextButton #ProfileTabActivity { Text: "Activity"; Style: @CommandButton; FlexWeight: 1; }
            }

            Label #SelectedModuleTitle {
              Text: "Selected Player";
              Anchor: (Height: 20, Bottom: 4);
              Style: (FontSize: 11, TextColor: #8fb6e8, RenderBold: true);
            }

            Group #SelectedModuleListContainer {
              LayoutMode: TopScrolling;
              FlexWeight: 1;
              Padding: (Top: 7, Bottom: 7, Left: 8, Right: 8);
              Background: (Color: #0b1524);
              OutlineColor: #355986;
              OutlineSize: 1;
              Group #SelectedModuleList { LayoutMode: Top; }
            }

            Group #PendingConfirmPanel {
              LayoutMode: Left;
              Visible: false;
              Anchor: (Height: 56, Top: 8);
              Padding: (Top: 6, Bottom: 6, Left: 8, Right: 8);
              Background: (Color: #24151b);
              OutlineColor: #8b3c48;
              OutlineSize: 1;
              Label #PendingConfirmText { Text: ""; FlexWeight: 1; Anchor: (Vertical: 0, Right: 6); Style: (FontSize: 10, TextColor: #ffb7c0, Wrap: true); }
              TextButton #ConfirmActionButton { Text: "Confirm"; Style: @CommandButtonRed; Anchor: (Width: 82, Height: 32, Vertical: 0, Right: 5); }
              TextButton #CancelActionButton { Text: "Cancel"; Style: @CommandButton; Anchor: (Width: 76, Height: 32, Vertical: 0); }
            }

            Group #DangerActionsPanel {
              LayoutMode: Top;
              Visible: false;
              Anchor: (Height: 66, Top: 8);
              Label { Text: "Danger Zone"; Anchor: (Height: 16, Bottom: 4); Style: (FontSize: 10, TextColor: #ff9f9f, RenderBold: true); }
              Group { LayoutMode: Left; Anchor: (Height: 30);
                TextButton #BanButton { Text: "Ban"; Style: @CommandButtonRed; FlexWeight: 1; Anchor: (Right: 5); }
                TextButton #UnbanButton { Text: "Unban"; Style: @CommandButtonGreen; FlexWeight: 1; Anchor: (Right: 5); }
                TextButton #ClearWarningsButton { Text: "Clear Warns"; Style: @CommandButtonRed; FlexWeight: 1; Anchor: (Right: 5); }
                TextButton #ResetBalanceButton { Text: "Reset $"; Style: @CommandButtonRed; FlexWeight: 1; }
              }
            }

            Group #TravelActionsPanel {
              LayoutMode: Left;
              Visible: false;
              Anchor: (Height: 34, Top: 8);
              TextButton #TeleportToButton { Text: "Teleport To"; Style: @CommandButton; FlexWeight: 1; Anchor: (Right: 5); }
              TextButton #TeleportHereButton { Text: "Bring Here"; Style: @CommandButton; FlexWeight: 1; }
            }

            TextButton #ToggleActionsButton {
              Text: "Hide Actions";
              Style: @CommandButton;
              Anchor: (Height: 28, Top: 8, Bottom: 8);
            }

            Group #ActionDrawer {
              LayoutMode: Top;
              Anchor: (Height: 190);

              Label { Text: "Reason Presets"; Anchor: (Height: 14, Bottom: 3); Style: (FontSize: 10, TextColor: #8fb6e8, RenderBold: true); }
              Group { LayoutMode: Left; Anchor: (Height: 24, Bottom: 4);
                TextButton #ReasonSpamButton { Text: "Spam"; Style: @CommandButton; FlexWeight: 1; Anchor: (Right: 5); }
                TextButton #ReasonHarassmentButton { Text: "Harassment"; Style: @CommandButton; FlexWeight: 1; Anchor: (Right: 5); }
                TextButton #ReasonExploitingButton { Text: "Exploiting"; Style: @CommandButton; FlexWeight: 1; }
              }
              Group { LayoutMode: Left; Anchor: (Height: 24, Bottom: 5);
                TextButton #ReasonChargebackButton { Text: "Chargeback"; Style: @CommandButton; FlexWeight: 1; Anchor: (Right: 5); }
                TextButton #ReasonAltButton { Text: "Alt Abuse"; Style: @CommandButton; FlexWeight: 1; }
              }

              Group {
                LayoutMode: Top;
                Anchor: (Height: 54, Bottom: 5);
                Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
                Background: (Color: #0b1524);
                OutlineColor: #355986;
                OutlineSize: 1;
                Label { Text: "Action Reason / Staff Note"; Anchor: (Height: 14, Bottom: 3); Style: (FontSize: 10, TextColor: #9ab6d9, RenderBold: true); }
                TextField #BanReasonInput { Anchor: (Height: 28); Style: (FontSize: 12, TextColor: #f0f5ff); }
              }

              Group { LayoutMode: Left; Anchor: (Height: 26, Bottom: 5);
                TextButton #FreezeButton { Text: "Freeze"; Style: @CommandButtonGold; FlexWeight: 1; Anchor: (Right: 5); }
                TextButton #UnfreezeButton { Text: "Unfreeze"; Style: @CommandButtonGreen; FlexWeight: 1; Anchor: (Right: 5); }
                TextButton #MuteButton { Text: "Mute"; Style: @CommandButtonGold; FlexWeight: 1; }
              }
              Group { LayoutMode: Left; Anchor: (Height: 26);
                TextButton #UnmuteButton { Text: "Unmute"; Style: @CommandButtonGreen; FlexWeight: 1; Anchor: (Right: 5); }
                TextButton #WarnButton { Text: "Warn"; Style: @CommandButtonGold; FlexWeight: 1; Anchor: (Right: 5); }
                TextButton #AddNoteButton { Text: "Add Note"; Style: @CommandButton; FlexWeight: 1; }
              }
            }
          }
        }
      }

      Group #ModerationContent {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;

        Group #ModStats {
          LayoutMode: Left;
          Anchor: (Height: 88, Bottom: 10);

          Group { LayoutMode: Top; Background: (Color: #111f34); FlexWeight: 1; Anchor: (Right: 8); Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10); OutlineColor: #2f4a72; OutlineSize: 1;
            Label { Text: "BANS"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #BanCountValue { Text: "0"; Style: (FontSize: 23, TextColor: #ff9f82, RenderBold: true); }
          }
          Group { LayoutMode: Top; Background: (Color: #111f34); FlexWeight: 1; Anchor: (Right: 8); Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10); OutlineColor: #2f4a72; OutlineSize: 1;
            Label { Text: "MUTES"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #MuteCountValue { Text: "0"; Style: (FontSize: 23, TextColor: #d5c47d, RenderBold: true); }
          }
          Group { LayoutMode: Top; Background: (Color: #111f34); FlexWeight: 1; Anchor: (Right: 8); Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10); OutlineColor: #2f4a72; OutlineSize: 1;
            Label { Text: "FROZEN"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #FrozenCountValue { Text: "0"; Style: (FontSize: 23, TextColor: #8fd3ff, RenderBold: true); }
          }
          Group { LayoutMode: Top; Background: (Color: #111f34); FlexWeight: 1; Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10); OutlineColor: #2f4a72; OutlineSize: 1;
            Label { Text: "IP BANS"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #IpBanCountValue { Text: "0"; Style: (FontSize: 23, TextColor: #ff7d7d, RenderBold: true); }
          }
        }

        Group {
          LayoutMode: Left;
          FlexWeight: 1;

          Group {
            LayoutMode: Top;
            Background: (Color: #111f34);
            FlexWeight: 1;
            Anchor: (Right: 10);
            Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Label { Text: "Active Moderation Queue"; Anchor: (Height: 22, Bottom: 8); Style: (FontSize: 13, TextColor: #d7e7ff, RenderBold: true); }
            Group #ModerationQueueContainer {
              LayoutMode: TopScrolling;
              FlexWeight: 1;
              Group #ModerationQueue { LayoutMode: Top; }
            }
          }

          Group {
            LayoutMode: Top;
            Background: (Color: #111f34);
            Anchor: (Width: 310);
            Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Label { Text: "Moderation Workflows"; Anchor: (Height: 24, Bottom: 8); Style: (FontSize: 13, TextColor: #d7e7ff, RenderBold: true); }
            Label { Text: "Use the Players tab for freeze, mute, warnings, ban, unban, and teleport actions."; Anchor: (Height: 44, Bottom: 8); Style: (FontSize: 11, TextColor: #a7c2e6, Wrap: true); }
            TextButton #OpenBansModerationButton { Text: "Open Ban List"; Style: @CommandButtonGold; Anchor: (Height: 34, Bottom: 8); }
            Label { Text: "Recent staff activity"; Anchor: (Height: 18, Bottom: 4); Style: (FontSize: 11, TextColor: #8fb6e8, RenderBold: true); }
            Group #StaffActivityList { LayoutMode: Top; FlexWeight: 1; }
          }
        }
      }

      Group #SystemsContent {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;

        Group #SystemGrid {
          LayoutMode: Top;
          FlexWeight: 1;
          Background: (Color: #111f34);
          Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Label { Text: "System Health"; Anchor: (Height: 26, Bottom: 8); Style: (FontSize: 14, TextColor: #d7e7ff, RenderBold: true); }
          Label #StorageValue { Text: "Storage"; Anchor: (Height: 30, Bottom: 5); Style: (FontSize: 12, TextColor: #8fd3ff); }
          Label #EconomyValue { Text: "Economy"; Anchor: (Height: 30, Bottom: 5); Style: (FontSize: 12, TextColor: #54e39e); }
          Label #ShopValue { Text: "Shops"; Anchor: (Height: 30, Bottom: 5); Style: (FontSize: 12, TextColor: #d5c47d); }
          Label #AuctionValue { Text: "Auction"; Anchor: (Height: 30, Bottom: 5); Style: (FontSize: 12, TextColor: #d0bbff); }
          Label #TravelValue { Text: "Travel"; Anchor: (Height: 30, Bottom: 5); Style: (FontSize: 12, TextColor: #a7c2e6); }
          Label #ProgressionValue { Text: "Progression"; Anchor: (Height: 30, Bottom: 5); Style: (FontSize: 12, TextColor: #f2be5c); }
          Group { FlexWeight: 1; }
          Label { Text: "This tab is intentionally read-only. Deeper editors live in Launch so risky changes stay in purpose-built panels."; Style: (FontSize: 11, TextColor: #8193aa, Wrap: true); Anchor: (Height: 46); }
        }
      }

      Group #LaunchContent {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;

        Group #LaunchGrid {
          LayoutMode: Top;
          Background: (Color: #111f34);
          FlexWeight: 1;
          Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Label { Text: "Admin Launchpad"; Anchor: (Height: 26, Bottom: 8); Style: (FontSize: 14, TextColor: #d7e7ff, RenderBold: true); }

          Group { LayoutMode: Left; Anchor: (Height: 54, Bottom: 8);
            TextButton #OpenEconomyButton { Text: "Economy Admin"; Style: @CommandButtonGreen; Anchor: (Width: 180, Right: 10); }
            Label #EconomyLaunchState { Text: ""; FlexWeight: 1; Anchor: (Vertical: 0); Style: (FontSize: 11, TextColor: #a7c2e6, Wrap: true); }
          }
          Group { LayoutMode: Left; Anchor: (Height: 54, Bottom: 8);
            TextButton #OpenPlaytimeButton { Text: "Playtime Admin"; Style: @CommandButtonGreen; Anchor: (Width: 180, Right: 10); }
            Label #PlaytimeLaunchState { Text: ""; FlexWeight: 1; Anchor: (Vertical: 0); Style: (FontSize: 11, TextColor: #a7c2e6, Wrap: true); }
          }
          Group { LayoutMode: Left; Anchor: (Height: 54, Bottom: 8);
            TextButton #OpenBansButton { Text: "Ban List"; Style: @CommandButtonGold; Anchor: (Width: 180, Right: 10); }
            Label #BanLaunchState { Text: ""; FlexWeight: 1; Anchor: (Vertical: 0); Style: (FontSize: 11, TextColor: #a7c2e6, Wrap: true); }
          }
          Group { LayoutMode: Left; Anchor: (Height: 54, Bottom: 8);
            TextButton #OpenShopsButton { Text: "Shop Directory"; Style: @CommandButtonGold; Anchor: (Width: 180, Right: 10); }
            Label #ShopLaunchState { Text: ""; FlexWeight: 1; Anchor: (Vertical: 0); Style: (FontSize: 11, TextColor: #a7c2e6, Wrap: true); }
          }
          Group { LayoutMode: Left; Anchor: (Height: 54, Bottom: 8);
            TextButton #OpenAuctionButton { Text: "Auction House"; Style: @CommandButtonGold; Anchor: (Width: 180, Right: 10); }
            Label #AuctionLaunchState { Text: ""; FlexWeight: 1; Anchor: (Vertical: 0); Style: (FontSize: 11, TextColor: #a7c2e6, Wrap: true); }
          }
          Group { FlexWeight: 1; }
        }
      }
    }
  }
}

$C = "../Common.ui";

$C.@PageOverlay {
  $C.@Container {
    Anchor: (Width: 680, Height: 520);

    #Title {
      Group {
        Background: (Color: #1e3a5e);
        Anchor: (Height: 48);
        Padding: (Left: 20, Right: 20);
        Label {
          Style: (
            FontSize: 20,
            RenderBold: true,
            TextColor: #ffffff,
            HorizontalAlignment: Center,
            VerticalAlignment: Center
          );
          Text: "FACTION MENU";
          Anchor: (Horizontal: 0, Vertical: 0);
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 24, Right: 24, Top: 20, Bottom: 20);

      Group #FactionInfoSection {
        LayoutMode: Top;
        Background: (Color: #2a3a4a);
        Padding: (Left: 16, Right: 16, Top: 12, Bottom: 12);
        Anchor: (Bottom: 16);

        Group #FactionInfoRow {
          LayoutMode: Left;
          Anchor: (Height: 28);
          Padding: (Bottom: 10);

          Label {
            Style: (
              FontSize: 13,
              TextColor: #b0c4de,
              VerticalAlignment: Center
            );
            Text: "Your Faction:";
            Anchor: (Width: 110, Vertical: 0);
          }

          Label #FactionName {
            Style: (
              FontSize: 16,
              RenderBold: true,
              TextColor: #ffffff,
              VerticalAlignment: Center
            );
            FlexWeight: 1;
            Anchor: (Vertical: 0);
          }
        }

        Label #MemberCount {
          Style: (
            FontSize: 12,
            TextColor: #a0b0c0,
            VerticalAlignment: Center
          );
          Anchor: (Height: 20);
          Padding: (Bottom: 8);
        }

        Label {
          Style: (
            FontSize: 11,
            TextColor: #8899aa,
            VerticalAlignment: Center
          );
          Text: "Use /hf invite <player> to invite";
          Anchor: (Height: 18);
        }
      }

      Label {
        Style: (
          FontSize: 15,
          RenderBold: true,
          TextColor: #ffffff,
          LetterSpacing: 0.5
        );
        Text: "MEMBERS";
        Anchor: (Height: 28);
        Padding: (Bottom: 8);
      }

      Group #MemberList {
        Anchor: (Width: 632, Height: 240);
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Background: (Color: #1a2a3a);
        Padding: (Left: 8, Right: 8, Top: 8, Bottom: 12);
      }

      Label {
        FlexWeight: 1;
      }

      Group #BottomButtons {
        LayoutMode: Left;
        Anchor: (Height: 44);
        Padding: (Top: 4);

        TextButton #ChunkBtn {
          Anchor: (Width: 100, Height: 36);
          Background: (Color: #2d5a4a);
          Style: TextButtonStyle(
            Default: (
              LabelStyle: (
                FontSize: 12,
                RenderBold: true,
                TextColor: #ffffff,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Hovered: (
              Background: (Color: #3d7a6a),
              LabelStyle: (
                FontSize: 12,
                RenderBold: true,
                TextColor: #ffffff,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Sounds: $C.@ButtonSounds
          );
          Text: "CLAIM";
        }

        Group {
          Anchor: (Width: 10);
        }

        TextButton #ViewAllBtn {
          Anchor: (Width: 110, Height: 36);
          Background: (Color: #3d5a7a);
          Style: TextButtonStyle(
            Default: (
              LabelStyle: (
                FontSize: 12,
                RenderBold: true,
                TextColor: #ffffff,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Hovered: (
              Background: (Color: #4d7a9a),
              LabelStyle: (
                FontSize: 12,
                RenderBold: true,
                TextColor: #ffffff,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Sounds: $C.@ButtonSounds
          );
          Text: "FACTIONS";
        }

        Group {
          Anchor: (Width: 10);
        }

        TextButton #ManageAlliesBtn {
          Anchor: (Width: 100, Height: 36);
          Background: (Color: #3d5a7a);
          Style: TextButtonStyle(
            Default: (
              LabelStyle: (
                FontSize: 12,
                RenderBold: true,
                TextColor: #ffffff,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Hovered: (
              Background: (Color: #4d7a9a),
              LabelStyle: (
                FontSize: 12,
                RenderBold: true,
                TextColor: #ffffff,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Sounds: $C.@ButtonSounds
          );
          Text: "ALLIES";
        }

        Group {
          Anchor: (Width: 10);
        }

        TextButton #WikiBtn {
          Anchor: (Width: 80, Height: 36);
          Background: (Color: #5a3a7a);
          Style: TextButtonStyle(
            Default: (
              LabelStyle: (
                FontSize: 12,
                RenderBold: true,
                TextColor: #ffffff,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Hovered: (
              Background: (Color: #6a4a8a),
              LabelStyle: (
                FontSize: 12,
                RenderBold: true,
                TextColor: #e0e7ff,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Sounds: $C.@ButtonSounds
          );
          Text: "WIKI";
        }

        Label {
          FlexWeight: 1;
        }

        TextButton #DisbandBtn {
          Anchor: (Width: 100, Height: 36);
          Background: (Color: #7a3a3a);
          Style: TextButtonStyle(
            Default: (
              LabelStyle: (
                FontSize: 12,
                RenderBold: true,
                TextColor: #ffffff,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Hovered: (
              Background: (Color: #9a4a4a),
              LabelStyle: (
                FontSize: 12,
                RenderBold: true,
                TextColor: #ffffff,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Sounds: $C.@ButtonSounds
          );
          Text: "DISBAND";
        }
      }
    }
  }
}

$C.@BackButton {}

$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 1120, Height: 760);

    #Title {
      Group {
        $C.@Title {
          @Text = "";
        }

        Label {
          Anchor: (Full: 0);
          Style: (FontSize: 24, TextColor: #f5f7ff, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "Auction House";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Horizontal: 14, Top: 2, Bottom: 14);

      Group #HeaderBar {
        Anchor: (Height: 66, Bottom: 10);
        LayoutMode: Left;
        Padding: (Left: 14, Right: 36, Top: 8, Bottom: 8);
        Background: (Color: #191714(0.92));
        OutlineColor: #7d6b3a;
        OutlineSize: 1;

        Group #BalanceCard {
          Anchor: (Width: 230, Height: 48, Right: 12);
          LayoutMode: Top;
          Padding: (Left: 12, Right: 12, Top: 5, Bottom: 5);
          Background: (Color: #2a2318(0.9));

          Label {
            Anchor: (Height: 14);
            Style: (FontSize: 10, TextColor: #b8aa7b, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "WALLET BALANCE";
          }

          Label #AuctionBalanceValue {
            Anchor: (Height: 24);
            Style: (FontSize: 19, TextColor: #ffd166, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 11);
            Text: "$0";
          }
        }

        Group #SearchCard {
          FlexWeight: 1;
          Anchor: (Height: 48, Right: 12);
          LayoutMode: Left;
          Padding: (Left: 12, Right: 12, Top: 7, Bottom: 7);
          Background: (Color: #141617(0.84));

          $C.@TextField #AuctionSearchInput {
            FlexWeight: 1;
            Anchor: (Height: 34, Vertical: 0);
            PlaceholderText: "Search item or seller...";
          }

          $C.@SecondaryTextButton #ClearAuctionSearchButton {
            Anchor: (Width: 98, Height: 34, Left: 8, Vertical: 0);
            Text: "Clear";
          }
        }

        Group #ResultCard {
          Anchor: (Width: 150, Height: 48, Right: 12);
          LayoutMode: Top;
          Padding: (Left: 12, Right: 12, Top: 5, Bottom: 5);
          Background: (Color: #141617(0.84));

          Label {
            Anchor: (Height: 14);
            Style: (FontSize: 10, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "MARKET";
          }

          Label #ResultInfo {
            Anchor: (Height: 24);
            Style: (FontSize: 15, TextColor: #d8e2f0, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 10);
            Text: "0 listings";
          }
        }

        $C.@TextButton #CloseButton {
          Anchor: (Width: 54, Height: 34, Vertical: 0);
          Text: "X";
        }

        $C.@SecondaryTextButton #BackToParentButton {
          Anchor: (Width: 92, Height: 34, Left: 8, Vertical: 0);
          Text: "Back";
          Visible: false;
        }
      }

      Group #BodyRow {
        FlexWeight: 1;
        LayoutMode: Left;

        Group #SidebarPanel {
          Anchor: (Width: 190, Right: 12);
          LayoutMode: Top;
          Padding: (Left: 10, Right: 10, Top: 12, Bottom: 12);
          Background: (Color: #151515(0.84));
          OutlineColor: #3a3425;
          OutlineSize: 1;

          Label {
            Anchor: (Height: 22, Bottom: 8);
            Style: (FontSize: 13, TextColor: #cbd5e1, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "AUCTION";
          }

          Group {
            Anchor: (Height: 1, Bottom: 10);
            Background: (Color: #93844c(0.45));
          }

          $C.@TextButton #TabBrowse {
            Text: "Browse";
            Anchor: (Horizontal: 0, Height: 32, Bottom: 8);
          }

          $C.@TextButton #TabMine {
            Text: "My Listings";
            Anchor: (Horizontal: 0, Height: 32, Bottom: 8);
          }

          $C.@TextButton #TabList {
            Text: "List Item";
            Anchor: (Horizontal: 0, Height: 32, Bottom: 12);
          }

          Group {
            Anchor: (Height: 1, Bottom: 10);
            Background: (Color: #93844c(0.25));
          }

          Label {
            Anchor: (Height: 18, Bottom: 6);
            Style: (FontSize: 11, TextColor: #a8abb2, HorizontalAlignment: Center);
            Text: "Sort";
          }

          $C.@TextButton #SortEndingButton {
            Text: "Ending Soon";
            Anchor: (Horizontal: 0, Height: 30, Bottom: 6);
          }

          $C.@TextButton #SortPriceLowButton {
            Text: "Price Low";
            Anchor: (Horizontal: 0, Height: 30, Bottom: 6);
          }

          $C.@TextButton #SortPriceHighButton {
            Text: "Price High";
            Anchor: (Horizontal: 0, Height: 30, Bottom: 12);
          }

          Group {
            Anchor: (Height: 1, Bottom: 10);
            Background: (Color: #93844c(0.25));
          }

          Label {
            Anchor: (Height: 18, Bottom: 4);
            Style: (FontSize: 11, TextColor: #a8abb2, HorizontalAlignment: Center);
            Text: "Listings are shared";
          }

          Label {
            Anchor: (Height: 18, Bottom: 6);
            Style: (FontSize: 12, TextColor: #d8e2f0, HorizontalAlignment: Center, RenderBold: true);
            Text: "across every NPC";
          }

          Group { FlexWeight: 1; }

          Group #Pager {
            Anchor: (Height: 96);
            LayoutMode: Top;

            $C.@TextButton #PrevPage {
              Anchor: (Horizontal: 0, Height: 30, Bottom: 8);
              Text: "< Prev";
            }

            Label #PageInfo {
              Anchor: (Horizontal: 0, Height: 22, Bottom: 8);
              Style: (FontSize: 12, TextColor: #b8b8b8, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "Page 1/1";
            }

            $C.@TextButton #NextPage {
              Anchor: (Horizontal: 0, Height: 30);
              Text: "Next >";
            }
          }
        }

        Group #MainPanel {
          FlexWeight: 1;
          LayoutMode: Top;

          Group #RowsContainer {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Right: 6);

            Label #EmptyLabel {
              Anchor: (Height: 68);
              Style: (FontSize: 15, TextColor: #777777, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "No active listings";
              Visible: false;
            }

            Group #AuctionRows {
              LayoutMode: Top;
            }
          }

          Group #ListingPanel {
            FlexWeight: 1;
            LayoutMode: Top;
            Visible: false;
            Padding: (Left: 12, Right: 12, Top: 12, Bottom: 12);
            Background: (Color: #151515(0.84));
            OutlineColor: #3a3425;
            OutlineSize: 1;

            Group #ListingHeader {
              Anchor: (Height: 54, Bottom: 12);
              LayoutMode: Top;

              Label {
                Anchor: (Height: 26);
                Style: (FontSize: 19, TextColor: #f5f3e8, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "Create Listing";
              }

              Label {
                Anchor: (Height: 20);
                Style: (FontSize: 12, TextColor: #a8abb2, VerticalAlignment: Center);
                Text: "Set a price and duration for the item in your hand.";
              }
            }

            Group {
              Anchor: (Height: 1, Bottom: 14);
              Background: (Color: #93844c(0.35));
            }

            Group #InputRow {
              Anchor: (Height: 82, Bottom: 12);
              LayoutMode: Left;

              Group #PriceBox {
                FlexWeight: 1;
                Anchor: (Right: 12);
                LayoutMode: Top;
                Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);
                Background: (Color: #241917(0.78));

                Label {
                  Anchor: (Height: 18, Bottom: 6);
                  Style: (FontSize: 12, TextColor: #ffcf7a, RenderBold: true);
                  Text: "PRICE";
                }

                $C.@TextField #PriceInput {
                  Anchor: (Horizontal: 0, Height: 38);
                  PlaceholderText: "0.00";
                }
              }

              Group #DurationBox {
                FlexWeight: 1;
                LayoutMode: Top;
                Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);
                Background: (Color: #14211b(0.78));

                Label {
                  Anchor: (Height: 18, Bottom: 6);
                  Style: (FontSize: 12, TextColor: #7ee0a8, RenderBold: true);
                  Text: "HOURS";
                }

                $C.@TextField #HoursInput {
                  Anchor: (Horizontal: 0, Height: 38);
                  PlaceholderText: "Default";
                }
              }
            }

            Group #ListingMeta {
              Anchor: (Height: 44, Bottom: 12);
              LayoutMode: Left;

              Group {
                FlexWeight: 1;
                Anchor: (Right: 12);
                Background: (Color: #111417(0.9));

                Label #ListCost {
                  Anchor: (Full: 0);
                  Style: (FontSize: 13, TextColor: #d8e2f0, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9);
                  Text: "Listing cost: $0";
                }
              }

              Group {
                FlexWeight: 1;
                Background: (Color: #111417(0.9));

                Label #DefaultDuration {
                  Anchor: (Full: 0);
                  Style: (FontSize: 13, TextColor: #d8e2f0, HorizontalAlignment: Center, VerticalAlignment: Center);
                  Text: "Default: 48h";
                }
              }
            }

            Group { FlexWeight: 1; }

            $C.@TextButton #ListHeldButton {
              Anchor: (Width: 190, Height: 38);
              Text: "List Held Item";
            }
          }
        }
      }
    }
  }
}

$C.@BackButton {}

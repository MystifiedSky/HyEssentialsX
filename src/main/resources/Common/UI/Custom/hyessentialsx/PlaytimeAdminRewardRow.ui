Button #RewardRow {
  LayoutMode: Left;
  Background: (Color: #16283f);
  Padding: (Top: 7, Bottom: 7, Left: 10, Right: 10);
  Anchor: (Left: 0, Right: 0, Height: 38, Bottom: 4);

  Group #SelectionIndicator {
    Background: (Color: #3fd1ff);
    Anchor: (Width: 4, Top: 0, Bottom: 0, Right: 8);
    Visible: false;
  }

  Label #RewardId {
    Text: "reward_id";
    Style: (FontSize: 12, TextColor: #f4f8ff, RenderBold: true);
    FlexWeight: 1;
    Anchor: (Vertical: 0);
  }

  Label #RewardRequired {
    Text: "1h";
    Style: (FontSize: 11, TextColor: #8fd3ff);
    Anchor: (Width: 90, Vertical: 0);
  }

  Label #RewardCommands {
    Text: "1 command(s)";
    Style: (FontSize: 11, TextColor: #c6dbfb, HorizontalAlignment: End);
    Anchor: (Width: 120, Vertical: 0);
  }
}

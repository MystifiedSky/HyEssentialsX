$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    @CloseButton = true;
    Anchor: (Width: 820, Height: 660);

    #Title {
      Group {
        $C.@Title { @Text = ""; }

        Label {
          Anchor: (Full: 0);
          Style: (FontSize: 24, TextColor: #f5f7ff, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "Server Rules";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Horizontal: 14, Top: 2, Bottom: 14);

      Group #HeaderRow {
        Anchor: (Horizontal: 0, Height: 66, Bottom: 10);
        LayoutMode: Left;
        Padding: (Left: 14, Right: 14, Top: 8, Bottom: 8);
        Background: (Color: #191714(0.92));
        OutlineColor: #7d6b3a;
        OutlineSize: 1;

        Group {
          Anchor: (Width: 210, Height: 48, Right: 12);
          LayoutMode: Top;
          Padding: (Left: 12, Right: 12, Top: 5, Bottom: 5);
          Background: (Color: #2a2318(0.9));

          Label {
            Anchor: (Height: 14);
            Style: (FontSize: 10, TextColor: #b8aa7b, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "RULES";
          }

          Label #RuleCount {
            Text: "0 Rules";
            Anchor: (Height: 24);
            Style: (FontSize: 17, TextColor: #ffd166, RenderBold: true, VerticalAlignment: Center);
          }
        }

        Group {
          FlexWeight: 1;
          Anchor: (Height: 48);
          LayoutMode: Top;
          Padding: (Left: 12, Right: 12, Top: 5, Bottom: 5);
          Background: (Color: #141617(0.84));

          Label {
            Anchor: (Height: 14);
            Style: (FontSize: 10, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "RANGE";
          }

          Label #RangeInfo {
            Text: "Showing 0-0 of 0";
            Anchor: (Height: 24);
            Style: (FontSize: 15, TextColor: #d8e2f0, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 10);
          }
        }
      }

      Group #RuleListFrame {
        LayoutMode: Top;
        FlexWeight: 1;
        Background: (Color: #151515(0.84));
        OutlineColor: #3a3425;
        OutlineSize: 1;
        Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);

        Group #RuleListContainer {
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          FlexWeight: 1;

          Group #RuleList {
            LayoutMode: Top;
          }
        }
      }

      Group #FooterRow {
        Anchor: (Horizontal: 0, Height: 44, Top: 10);
        LayoutMode: Left;
        Padding: (Left: 14, Right: 14, Top: 5, Bottom: 5);
        Background: (Color: #111417(0.9));

        Group { FlexWeight: 1; }

        $C.@TextButton #PrevButton {
          Anchor: (Width: 98, Height: 34, Vertical: 0, Right: 8);
          Text: "< Prev";
        }

        Label #PageInfo {
          Text: "Page 1/1";
          Style: (FontSize: 12, TextColor: #aaaaaa, HorizontalAlignment: Center, VerticalAlignment: Center);
          Anchor: (Width: 130, Height: 34, Right: 8);
        }

        $C.@TextButton #NextButton {
          Anchor: (Width: 98, Height: 34, Vertical: 0);
          Text: "Next >";
        }
      }
    }
  }
}

$C.@BackButton {}

$E = "EcoCommon.ui";

Group #PlaytimeAdminRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  LayoutMode: Center;

  Group #PlaytimeAdminShell {
    Anchor: (Width: 980, Height: 620);
    LayoutMode: Left;
    Background: (Color: #0e1727ef);
    OutlineColor: #2f4a72;
    OutlineSize: 1;

    Group #Sidebar {
      LayoutMode: Top;
      Background: (Color: #111f34);
      Anchor: (Width: 198, Top: 0, Bottom: 0);
      Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);
      OutlineColor: #2f4a72;
      OutlineSize: 1;

      Group #BrandBlock {
        LayoutMode: Top;
        Background: (Color: #173055);
        Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);
        Anchor: (Height: 110, Bottom: 12);
        OutlineColor: #3a6498;
        OutlineSize: 1;

        Label {
          Text: "HyEssentialsX Playtime Admin Panel";
          Style: (FontSize: 12, TextColor: #f2f7ff, RenderBold: true, Wrap: true);
          Anchor: (Left: 0, Right: 0, Height: 34, Bottom: 4);
        }

        Label {
          Text: "Manage playtime rewards and settings";
          Style: (FontSize: 10, TextColor: #9ab6d9, Wrap: true);
          Anchor: (Left: 0, Right: 0);
        }
      }

      TextButton #TabDashboard {
        Text: "Dashboard";
        Style: $E.@EcoButtonStyle;
        Anchor: (Height: 34, Bottom: 6);
      }
      TextButton #TabRewards {
        Text: "Rewards";
        Style: $E.@EcoButtonStyle;
        Anchor: (Height: 34, Bottom: 6);
      }
      TextButton #TabTop {
        Text: "Top";
        Style: $E.@EcoButtonStyle;
        Anchor: (Height: 34, Bottom: 6);
      }
      TextButton #TabConfig {
        Text: "Config";
        Style: $E.@EcoButtonStyle;
        Anchor: (Height: 34, Bottom: 12);
      }

      Group { FlexWeight: 1; }

      TextButton #BackToParentButton {
        Text: "Back";
        Style: $E.@EcoButtonStyle;
        Anchor: (Height: 34, Bottom: 8);
        Visible: false;
      }

      TextButton #CloseButton {
        Text: "Close";
        Style: $E.@EcoButtonRedStyle;
        Anchor: (Height: 34);
      }
    }

    Group #Workspace {
      LayoutMode: Top;
      FlexWeight: 1;
      Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);

      Group #Header {
        LayoutMode: Left;
        Background: (Color: #111f34);
        Anchor: (Height: 52, Bottom: 10);
        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
        OutlineColor: #2f4a72;
        OutlineSize: 1;

        Label {
          Text: "Playtime Operations";
          Style: (FontSize: 16, TextColor: #f2f7ff, RenderBold: true);
          FlexWeight: 1;
          Anchor: (Vertical: 0);
        }

        Label {
          Text: "Realtime reward and config manager";
          Style: (FontSize: 11, TextColor: #8ca7cc);
          Anchor: (Vertical: 0);
        }
      }

      Group #DashboardContent {
        LayoutMode: Top;
        FlexWeight: 1;

        Group #DashboardStats {
          LayoutMode: Left;
          Anchor: (Height: 88, Bottom: 10);

          Group {
            LayoutMode: Top;
            Background: (Color: #111f34);
            FlexWeight: 1;
            Anchor: (Right: 8);
            Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Label { Text: "Tracked Players"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #TrackedPlayersValue { Text: "0"; Style: (FontSize: 22, TextColor: #8fd3ff, RenderBold: true); }
          }

          Group {
            LayoutMode: Top;
            Background: (Color: #111f34);
            FlexWeight: 1;
            Anchor: (Right: 8);
            Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Label { Text: "Total Playtime"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #TotalPlaytimeValue { Text: "0s"; Style: (FontSize: 22, TextColor: #54e39e, RenderBold: true); }
          }

          Group {
            LayoutMode: Top;
            Background: (Color: #111f34);
            FlexWeight: 1;
            Anchor: (Right: 8);
            Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Label { Text: "Average Playtime"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #AveragePlaytimeValue { Text: "0s"; Style: (FontSize: 22, TextColor: #f2be5c, RenderBold: true); }
          }

          Group {
            LayoutMode: Top;
            Background: (Color: #111f34);
            FlexWeight: 1;
            Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Label { Text: "Configured Rewards"; Style: (FontSize: 10, TextColor: #8ba6ca); }
            Label #RewardCountValue { Text: "0"; Style: (FontSize: 22, TextColor: #d0bbff, RenderBold: true); }
          }
        }

        Group {
          LayoutMode: TopScrolling;
          Background: (Color: #111f34);
          FlexWeight: 1;
          Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Label {
            Text: "Dashboard";
            Style: (FontSize: 12, TextColor: #d7e7ff, RenderBold: true);
            Anchor: (Bottom: 8);
          }

          Label #DashboardHint {
            Text: "";
            Style: (FontSize: 11, TextColor: #a7c2e6, Wrap: true);
            Anchor: (Left: 0, Right: 0);
          }
        }
      }

      Group #RewardsContent {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;

        Group {
          LayoutMode: Left;
          Anchor: (Height: 36, Bottom: 8);

          Label {
            Text: "Search:";
            Style: (FontSize: 11, TextColor: #9ab6d9);
            Anchor: (Width: 54, Vertical: 0);
          }

          Group {
            Background: (Color: #0b1524);
            Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
            FlexWeight: 1;
            Anchor: (Height: 30, Right: 10);
            OutlineColor: #355986;
            OutlineSize: 1;

            TextField #RewardSearch {
              Style: (FontSize: 13, TextColor: #f0f5ff);
              FlexWeight: 1;
            }
          }

          Label #SelectedRewardLabel {
            Text: "Selected: none";
            Style: (FontSize: 11, TextColor: #8da8cc);
            Anchor: (Vertical: 0);
          }
        }

        Group {
          LayoutMode: Left;
          FlexWeight: 1;
          Anchor: (Bottom: 10);

          Group #RewardListContainer {
            LayoutMode: Top;
            Background: (Color: #111f34);
            FlexWeight: 1;
            Anchor: (Right: 10);
            Padding: (Top: 8, Bottom: 8, Left: 8, Right: 8);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Group {
              LayoutMode: TopScrolling;
              FlexWeight: 1;

              Group #RewardList { LayoutMode: Top; }
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 28, Top: 8);

              TextButton #RewardPrevPageButton { Text: "< Prev"; Style: $E.@EcoButtonStyle; Anchor: (Width: 70, Height: 24, Vertical: 0); }
              Label #RewardPageInfo { Text: "Page 1/1"; Style: (FontSize: 11, TextColor: #8da8cc, HorizontalAlignment: Center); FlexWeight: 1; Anchor: (Vertical: 0); }
              TextButton #RewardNextPageButton { Text: "Next >"; Style: $E.@EcoButtonStyle; Anchor: (Width: 70, Height: 24, Vertical: 0); }
            }
          }

          Group #RewardEditor {
            LayoutMode: Top;
            Background: (Color: #111f34);
            Anchor: (Width: 320);
            Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);
            OutlineColor: #2f4a72;
            OutlineSize: 1;

            Label {
              Text: "Reward Editor";
              Style: (FontSize: 12, TextColor: #d7e7ff, RenderBold: true);
              Anchor: (Bottom: 8);
            }

            Label { Text: "Reward ID"; Style: (FontSize: 10, TextColor: #9ab6d9); Anchor: (Bottom: 2); }
            Group {
              Background: (Color: #0b1524);
              Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
              Anchor: (Height: 30, Bottom: 8);
              OutlineColor: #355986;
              OutlineSize: 1;
              TextField #DraftIdInput { Style: (FontSize: 13, TextColor: #f0f5ff); FlexWeight: 1; }
            }

            Label { Text: "Required Time (30m, 2h, 1d)"; Style: (FontSize: 10, TextColor: #9ab6d9); Anchor: (Bottom: 2); }
            Group {
              Background: (Color: #0b1524);
              Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
              Anchor: (Height: 30, Bottom: 6);
              OutlineColor: #355986;
              OutlineSize: 1;
              TextField #DraftRequiredInput { Style: (FontSize: 13, TextColor: #f0f5ff); FlexWeight: 1; }
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 48, Bottom: 6);

              Group {
                LayoutMode: Top;
                FlexWeight: 1;
                Anchor: (Right: 6);
                Label { Text: "Required Cost"; Style: (FontSize: 10, TextColor: #9ab6d9); Anchor: (Bottom: 2); }
                Group {
                  Background: (Color: #0b1524);
                  Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
                  Anchor: (Height: 30);
                  OutlineColor: #355986;
                  OutlineSize: 1;
                  TextField #DraftCostInput { Style: (FontSize: 13, TextColor: #f0f5ff); FlexWeight: 1; }
                }
              }

              Group {
                LayoutMode: Top;
                FlexWeight: 1;
                Label { Text: "Rank (for /rankup)"; Style: (FontSize: 10, TextColor: #9ab6d9); Anchor: (Bottom: 2); }
                Group {
                  Background: (Color: #0b1524);
                  Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
                  Anchor: (Height: 30);
                  OutlineColor: #355986;
                  OutlineSize: 1;
                  TextField #DraftRankInput { Style: (FontSize: 13, TextColor: #f0f5ff); FlexWeight: 1; }
                }
              }
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 32, Bottom: 6);
              Padding: (Top: 1, Bottom: 1);
              Label { Text: "Auto Claim"; Style: (FontSize: 10, TextColor: #9ab6d9); FlexWeight: 1; Anchor: (Height: 26, Vertical: 0); }
              TextButton #DraftAutoClaimToggle { Text: "ON"; Style: $E.@EcoButtonStyle; Anchor: (Width: 90, Height: 26, Vertical: 0); }
            }

            Label { Text: "Commands (| separated)"; Style: (FontSize: 10, TextColor: #9ab6d9); Anchor: (Bottom: 2); }
            Group {
              Background: (Color: #0b1524);
              Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
              Anchor: (Height: 30, Bottom: 6);
              OutlineColor: #355986;
              OutlineSize: 1;
              TextField #DraftCommandsInput { Style: (FontSize: 12, TextColor: #f0f5ff); FlexWeight: 1; }
            }

            Label { Text: "Broadcast Message"; Style: (FontSize: 10, TextColor: #9ab6d9); Anchor: (Bottom: 2); }
            Group {
              Background: (Color: #0b1524);
              Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
              Anchor: (Height: 30, Bottom: 8);
              OutlineColor: #355986;
              OutlineSize: 1;
              TextField #DraftBroadcastInput { Style: (FontSize: 12, TextColor: #f0f5ff); FlexWeight: 1; }
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 30, Bottom: 6);
              TextButton #SaveRewardButton { Text: "SAVE"; Style: $E.@EcoButtonAccentStyle; FlexWeight: 1; Anchor: (Height: 28, Vertical: 0, Right: 6); }
              TextButton #DeleteRewardButton { Text: "DELETE"; Style: $E.@EcoButtonRedStyle; Anchor: (Width: 88, Height: 28, Vertical: 0); }
            }

            TextButton #ClearDraftButton {
              Text: "CLEAR DRAFT";
              Style: $E.@EcoButtonStyle;
              Anchor: (Height: 28);
            }
          }
        }
      }

      Group #TopContent {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;

        Group #TopListHeader {
          LayoutMode: Left;
          Anchor: (Height: 28, Bottom: 4);
          Background: (Color: #0b1524);
          Padding: (Left: 10, Right: 10);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Label { Text: "Rank"; Style: (FontSize: 11, TextColor: #89a6cb, RenderBold: true); Anchor: (Width: 72, Vertical: 0); }
          Label { Text: "Player"; Style: (FontSize: 11, TextColor: #89a6cb, RenderBold: true); FlexWeight: 1; Anchor: (Vertical: 0); }
          Label { Text: "Playtime"; Style: (FontSize: 11, TextColor: #89a6cb, RenderBold: true, HorizontalAlignment: End); Anchor: (Width: 180, Vertical: 0); }
        }

        Group #TopListContainer {
          LayoutMode: TopScrolling;
          Background: (Color: #111f34);
          FlexWeight: 1;
          Padding: (Top: 8, Bottom: 8, Left: 8, Right: 8);
          OutlineColor: #2f4a72;
          OutlineSize: 1;
          Group #TopList { LayoutMode: Top; }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 28, Top: 8);
          Label #TopInfo {
            Text: "Showing 0 of 0 tracked players";
            Style: (FontSize: 11, TextColor: #8da8cc);
            FlexWeight: 1;
            Anchor: (Vertical: 0);
          }
        }
      }

      Group #ConfigContent {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;

        Group {
          LayoutMode: Left;
          Anchor: (Height: 36, Bottom: 10);

          TextButton #ReloadConfigButton { Text: "Reload"; Style: $E.@EcoButtonStyle; Anchor: (Width: 90, Height: 30); }
          TextButton #SaveConfigButton { Text: "Save"; Style: $E.@EcoButtonAccentStyle; Anchor: (Width: 90, Height: 30, Left: 8); }

          Label #ConfigStatus {
            Text: "";
            Style: (FontSize: 12, TextColor: #8da8cc);
            Anchor: (Vertical: 0, Left: 12);
          }
        }

        Group {
          LayoutMode: Top;
          Background: (Color: #111f34);
          FlexWeight: 1;
          Padding: (Top: 12, Bottom: 12, Left: 12, Right: 12);
          OutlineColor: #2f4a72;
          OutlineSize: 1;

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "Playtime GUI"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 180, Vertical: 0); }
            TextButton #CfgGuiToggle { Text: "ON"; Style: $E.@EcoButtonStyle; Anchor: (Width: 92, Height: 28, Vertical: 0); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "Rewards Enabled"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 180, Vertical: 0); }
            TextButton #CfgRewardsToggle { Text: "ON"; Style: $E.@EcoButtonStyle; Anchor: (Width: 92, Height: 28, Vertical: 0); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "Auto Claim Rewards"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 180, Vertical: 0); }
            TextButton #CfgAutoClaimToggle { Text: "ON"; Style: $E.@EcoButtonStyle; Anchor: (Width: 92, Height: 28, Vertical: 0); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "Require Playtime"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 180, Vertical: 0); }
            TextButton #CfgRankupPlaytimeToggle { Text: "ON"; Style: $E.@EcoButtonStyle; Anchor: (Width: 92, Height: 28, Vertical: 0); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "Require Currency"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 180, Vertical: 0); }
            TextButton #CfgRankupCurrencyToggle { Text: "ON"; Style: $E.@EcoButtonStyle; Anchor: (Width: 92, Height: 28, Vertical: 0); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "Auto Rankup"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 180, Vertical: 0); }
            TextButton #CfgRankupAutoToggle { Text: "OFF"; Style: $E.@EcoButtonStyle; Anchor: (Width: 92, Height: 28, Vertical: 0); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "Auto Uses Currency"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 180, Vertical: 0); }
            TextButton #CfgRankupAutoUseCurrencyToggle { Text: "OFF"; Style: $E.@EcoButtonStyle; Anchor: (Width: 92, Height: 28, Vertical: 0); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "Top Limit"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 180, Vertical: 0); }
            Group {
              Background: (Color: #0b1524);
              Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
              Anchor: (Width: 160, Height: 30, Vertical: 0);
              OutlineColor: #355986;
              OutlineSize: 1;
              TextField #CfgTopLimitInput { Style: (FontSize: 13, TextColor: #f0f5ff); FlexWeight: 1; }
            }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34, Bottom: 8);
            Label { Text: "Reward Check Interval (s)"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 180, Vertical: 0); }
            Group {
              Background: (Color: #0b1524);
              Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
              Anchor: (Width: 160, Height: 30, Vertical: 0);
              OutlineColor: #355986;
              OutlineSize: 1;
              TextField #CfgCheckIntervalInput { Style: (FontSize: 13, TextColor: #f0f5ff); FlexWeight: 1; }
            }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 34);
            Label { Text: "Auto Rankup Check (s)"; Style: (FontSize: 12, TextColor: #9ab6d9); Anchor: (Width: 180, Vertical: 0); }
            Group {
              Background: (Color: #0b1524);
              Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
              Anchor: (Width: 160, Height: 30, Vertical: 0);
              OutlineColor: #355986;
              OutlineSize: 1;
              TextField #CfgRankupAutoCheckInput { Style: (FontSize: 13, TextColor: #f0f5ff); FlexWeight: 1; }
            }
          }
        }
      }
    }
  }
}

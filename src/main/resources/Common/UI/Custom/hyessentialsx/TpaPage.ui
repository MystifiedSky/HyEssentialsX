$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    @CloseButton = true;
    Anchor: (Width: 760, Height: 600);

    #Title {
      Group {
        $C.@Title { @Text = ""; }

        Label {
          Anchor: (Full: 0);
          Style: (FontSize: 24, TextColor: #f5f7ff, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "Teleport Request";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Horizontal: 14, Top: 2, Bottom: 14);

      Group #HeaderRow {
        Anchor: (Horizontal: 0, Height: 66, Bottom: 10);
        LayoutMode: Left;
        Padding: (Left: 14, Right: 14, Top: 8, Bottom: 8);
        Background: (Color: #191714(0.92));
        OutlineColor: #7d6b3a;
        OutlineSize: 1;

        $C.@TextField #SearchInput {
          FlexWeight: 1;
          Anchor: (Height: 34, Vertical: 0, Right: 8);
          PlaceholderText: "Search player...";
        }

        $C.@SecondaryTextButton #SearchButton {
          @Text = "Search";
          Anchor: (Width: 110, Height: 34, Vertical: 0);
        }
      }

      Group #PlayerCountRow {
        Anchor: (Horizontal: 0, Height: 44, Bottom: 10);
        LayoutMode: Top;
        Padding: (Left: 12, Right: 12, Top: 5, Bottom: 5);
        Background: (Color: #141617(0.84));

        Label {
          Anchor: (Height: 14);
          Style: (FontSize: 10, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
          Text: "ONLINE PLAYERS";
        }

        Label #PlayerCount {
          Text: "0 Players";
          Anchor: (Height: 20);
          Style: (FontSize: 15, TextColor: #ffd166, RenderBold: true, VerticalAlignment: Center);
        }
      }

      Group #PlayerListFrame {
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
        Background: (Color: #151515(0.84));
        OutlineColor: #3a3425;
        OutlineSize: 1;

        Group #PlayerListContainer {
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          FlexWeight: 1;

          Group #PlayerList {
            LayoutMode: Top;
          }
        }
      }
    }
  }
}

$C.@BackButton {}

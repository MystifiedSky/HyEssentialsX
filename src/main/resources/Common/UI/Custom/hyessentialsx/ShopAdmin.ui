$C = "../Common.ui";

@TradeToggleButtonStyle = TextButtonStyle(
  Default: (Background: #2a2a2a(0.9), LabelStyle: (FontSize: 14, TextColor: #a5a5a5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #343434(0.95), LabelStyle: (FontSize: 14, TextColor: #d0d0d0, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #222222(0.98), LabelStyle: (FontSize: 14, TextColor: #f0f0f0, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Disabled: (Background: #3a6c46(0.95), LabelStyle: (FontSize: 14, TextColor: #f4fff4, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds,
);

$C.@PageOverlay {

  $C.@DecoratedContainer {
    Anchor: (Width: 1020, Height: 760);

    #Title {
      Group {
        $C.@Title {
          @Text = "Admin Shop";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 15, Right: 15, Top: 5, Bottom: 5);

      Group #TabBar {
        Anchor: (Height: 40, Bottom: 10);
        LayoutMode: Left;

        $C.@TextButton #TabTrades {
          Text: "Trades";
          Anchor: (Width: 160, Height: 35);
        }

        $C.@TextButton #TabSettings {
          Text: "Settings";
          Anchor: (Width: 160, Height: 35, Left: 4);
        }

        $C.@TextButton #TabPreview {
          Text: "Preview";
          Anchor: (Width: 160, Height: 35, Left: 4);
        }
      }

      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #93844c(0.5));
      }

      Group #TradesTabContent {
        FlexWeight: 1;
        LayoutMode: Top;
        Visible: true;

        Group #TradeListSection {
          Anchor: (Height: 225, Bottom: 8);
          LayoutMode: Top;

          Label {
            Anchor: (Bottom: 5);
            Style: (FontSize: 14, TextColor: #93844c, RenderBold: true);
            Text: "Current Trades";
          }

          Group #TradeList {
            Anchor: (Height: 200);
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Background: (Color: #0a0a0a(0.4));
            Padding: 5;

            Label #NoTradesLabel {
              Anchor: (Height: 30);
              Style: (FontSize: 14, TextColor: #666666);
              Text: "No trades configured yet";
              Visible: false;
            }

            Group #TradeCards {
              LayoutMode: Top;
            }
          }
        }

        Group #TradePager {
          Anchor: (Height: 32, Bottom: 10);
          LayoutMode: Left;

          Group { FlexWeight: 1; }

          $C.@TextButton #TradePrevPage {
            Anchor: (Width: 40, Height: 28);
            Text: "<";
          }

          Label #TradePageInfo {
            Anchor: (Width: 140);
            Style: (FontSize: 12, TextColor: #888888, HorizontalAlignment: Center);
            Text: "Page 1/1";
          }

          $C.@TextButton #TradeNextPage {
            Anchor: (Width: 40, Height: 28);
            Text: ">";
          }

          Group { FlexWeight: 1; }
        }

        Group {
          Anchor: (Height: 1, Bottom: 10);
          Background: (Color: #93844c(0.3));
        }

        Label {
          Anchor: (Bottom: 6);
          Style: (FontSize: 15, TextColor: #93844c, RenderBold: true);
          Text: "New Trade";
        }

        Group #PaymentTypeRow {
          Anchor: (Height: 32, Bottom: 5);
          LayoutMode: Left;

          Label {
            Anchor: (Width: 120);
            Style: (FontSize: 14, TextColor: #aaaaaa);
            Text: "Payment:";
          }

          $C.@TextButton #PaymentMoney {
            Text: "Money";
            Anchor: (Width: 120, Height: 28);
            Style: @TradeToggleButtonStyle;
          }

          $C.@TextButton #PaymentItems {
            Text: "Items";
            Anchor: (Width: 120, Height: 28, Left: 6);
            Style: @TradeToggleButtonStyle;
          }
        }

        Group #MoneySection {
          Anchor: (Height: 38, Bottom: 5);
          LayoutMode: Left;
          Visible: true;

          Label {
            Anchor: (Width: 120);
            Style: (FontSize: 14, TextColor: #ff8866, RenderBold: true);
            Text: "Price:";
          }

          Group {
            Anchor: (Width: 260);
            $C.@HeaderSearch #PriceInput {}
          }
        }

        Group #MoneyModeRow {
          Anchor: (Height: 32, Bottom: 5);
          LayoutMode: Left;
          Visible: true;

          Label {
            Anchor: (Width: 120);
            Style: (FontSize: 14, TextColor: #aaaaaa);
            Text: "Mode:";
          }

          $C.@TextButton #MoneyModeBuy {
            Text: "Buy";
            Anchor: (Width: 120, Height: 28);
            Style: @TradeToggleButtonStyle;
          }

          $C.@TextButton #MoneyModeSell {
            Text: "Sell";
            Anchor: (Width: 120, Height: 28, Left: 6);
            Style: @TradeToggleButtonStyle;
          }
        }

        Group #ItemCostSection {
          Anchor: (Height: 38, Bottom: 5);
          LayoutMode: Left;
          Visible: false;

          Label {
            Anchor: (Width: 110);
            Style: (FontSize: 14, TextColor: #ff8866, RenderBold: true);
            Text: "Cost Item:";
          }

          Group #SelectedCostItems {
            Anchor: (Width: 260);
            LayoutMode: Left;
          }

          $C.@TextButton #UseCostHand {
            Text: "Use Hand";
            Anchor: (Width: 220, Height: 28, Left: 6);
          }

          $C.@TextButton #ClearCost {
            Text: "Clear";
            Anchor: (Width: 160, Height: 28, Left: 6);
          }
        }

        Group #CostQtyRow {
          Anchor: (Height: 30, Bottom: 5);
          LayoutMode: Left;
          Visible: false;

          Label {
            Anchor: (Width: 120);
            Style: (FontSize: 12, TextColor: #aaaaaa);
            Text: "Cost Qty:";
          }

          Group {
            Anchor: (Width: 120, Left: 80);
            $C.@HeaderSearch #CostQtyInput {}
          }
        }

        Group #OutputSection {
          Anchor: (Height: 38, Bottom: 5);
          LayoutMode: Left;

          Label {
            Anchor: (Width: 110);
            Style: (FontSize: 14, TextColor: #66ff88, RenderBold: true);
            Text: "Output Item:";
          }

          Group #SelectedOutputItems {
            Anchor: (Width: 260);
            LayoutMode: Left;
          }

          $C.@TextButton #UseOutputHand {
            Text: "Use Hand";
            Anchor: (Width: 220, Height: 28, Left: 6);
          }

          $C.@TextButton #ClearOutput {
            Text: "Clear";
            Anchor: (Width: 160, Height: 28, Left: 6);
          }
        }

        Group #OutputQtyRow {
          Anchor: (Height: 30, Bottom: 5);
          LayoutMode: Left;
          Visible: true;

          Label {
            Anchor: (Width: 120);
            Style: (FontSize: 12, TextColor: #aaaaaa);
            Text: "Output Qty:";
          }

          Group {
            Anchor: (Width: 120, Left: 80);
            $C.@HeaderSearch #OutputQtyInput {}
          }
        }

        Group #StockLimitSection {
          Anchor: (Height: 34, Bottom: 4);
          LayoutMode: Left;

          Label {
            Anchor: (Width: 120);
            Style: (FontSize: 14, TextColor: #aaaaaa);
            Text: "Stock Limit:";
          }

          Group {
            Anchor: (Width: 200);
            $C.@HeaderSearch #StockLimitInput {}
          }

          Label {
            Anchor: (Width: 160, Left: 8);
            Style: (FontSize: 12, TextColor: #888888);
            Text: "0 = unlimited";
          }
        }

        Label #EditModeLabel {
          Anchor: (Height: 18, Bottom: 4);
          Style: (FontSize: 12, TextColor: #888888);
          Text: "";
        }

        Group #SaveSection {
          Anchor: (Height: 36);
          LayoutMode: Left;

          Group { FlexWeight: 1; }

          $C.@TextButton #SaveTradeButton {
            Text: "Save Trade";
            Anchor: (Width: 180, Height: 34);
          }

          Group { FlexWeight: 1; }
        }
      }

      Group #SettingsTabContent {
        FlexWeight: 1;
        LayoutMode: Top;
        Visible: false;

        Label {
          Anchor: (Bottom: 20);
          Style: (FontSize: 16, TextColor: #93844c, RenderBold: true);
          Text: "Shop Settings";
        }

        Group {
          Anchor: (Height: 50, Bottom: 15);
          LayoutMode: Left;

          Label {
            Anchor: (Width: 120);
            Style: (FontSize: 14, TextColor: #aaaaaa);
            Text: "Shop Name:";
          }

          Group {
            Anchor: (Width: 350);
            $C.@HeaderSearch #ShopNameInput {}
          }

          $C.@TextButton #SaveNameButton {
            Text: "Save";
            Anchor: (Width: 100, Height: 35, Left: 10);
          }
        }

        Label #CurrentShopName {
          Style: (FontSize: 14, TextColor: #888888);
          Text: "Current: Shop";
        }

        Group {
          Anchor: (Height: 1, Top: 20, Bottom: 20);
          Background: (Color: #93844c(0.3));
        }

        Group #NpcRoleSection {
          Anchor: (Height: 220, Bottom: 14);
          LayoutMode: Top;

          Group {
            Anchor: (Height: 40, Bottom: 6);
            LayoutMode: Left;

            Label {
              Anchor: (Width: 120);
              Style: (FontSize: 14, TextColor: #aaaaaa);
              Text: "NPC Model:";
            }

            Group {
              Anchor: (Width: 360);
              $C.@HeaderSearch #NpcRoleSearchInput {}
            }

            $C.@TextButton #ApplyNpcRole {
              Text: "Apply";
              Anchor: (Width: 120, Height: 28, Left: 10);
            }
          }

          Label #NpcRoleLabel {
            Anchor: (Height: 22, Bottom: 6);
            Style: (FontSize: 13, TextColor: #ffffff);
            Text: "Selected: None";
          }

          Group {
            Anchor: (Height: 28, Top: 6);
            LayoutMode: Left;

            Label #NpcRoleCount {
              Anchor: (Width: 180);
              Style: (FontSize: 12, TextColor: #aaaaaa, VerticalAlignment: Center);
              Text: "0 models";
            }

            $C.@TextButton #NpcRoleClearSearch {
              Text: "Clear";
              Anchor: (Width: 90, Height: 28, Left: 12);
            }
          }

          Group #NpcRoleResults {
            Anchor: (Height: 108, Top: 6);
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Background: (Color: #0a0a0a(0.35));
            Padding: 4;
          }
        }

        Group {
          Anchor: (Height: 40, Top: 10);
          LayoutMode: Left;

          Label {
            Anchor: (Width: 120);
            Style: (FontSize: 14, TextColor: #aaaaaa);
            Text: "Shop Status:";
          }

          Label #ShopStatusLabel {
            Anchor: (Width: 120);
            Style: (FontSize: 14, TextColor: #66ff66);
            Text: "Open";
          }

          $C.@TextButton #ToggleOpenButton {
            Text: "Toggle";
            Anchor: (Width: 140, Height: 35, Left: 12);
          }
        }

        Group #MoneyStockSection {
          Anchor: (Height: 45, Top: 12, Bottom: 6);
          LayoutMode: Left;

          Label {
            Anchor: (Width: 160);
            Style: (FontSize: 14, TextColor: #aaaaaa);
            Text: "Money stock limit:";
          }

          Group {
            Anchor: (Width: 120, Left: 59);
            $C.@HeaderSearch #MoneyStockLimitInput {}
          }

          Label {
            Anchor: (Width: 160, Left: 28);
            Style: (FontSize: 12, TextColor: #888888);
            Text: "0 = unlimited";
          }
        }

        Group #StockResetSection {
          Anchor: (Height: 45, Top: 6, Bottom: 8);
          LayoutMode: Left;

          Label {
            Anchor: (Width: 160);
            Style: (FontSize: 14, TextColor: #aaaaaa);
            Text: "Stock reset (days):";
          }

          Group {
            Anchor: (Width: 120, Left: 59);
            $C.@HeaderSearch #StockResetInput {}
          }

          $C.@TextButton #SaveStockSettings {
            Text: "Save";
            Anchor: (Width: 120, Height: 35, Left: 56);
          }
        }

        Group #PlayerShopSettings {
          Anchor: (Height: 150, Top: 10);
          LayoutMode: Top;
          Visible: false;

          Label {
            Anchor: (Bottom: 10);
            Style: (FontSize: 15, TextColor: #93844c, RenderBold: true);
            Text: "Player Shop Settings";
          }

          Group #EditorRow {
            Anchor: (Height: 40, Bottom: 6);
            LayoutMode: Left;

            Label {
              Anchor: (Width: 120);
              Style: (FontSize: 14, TextColor: #aaaaaa);
              Text: "Editors:";
            }

            Group {
              Anchor: (Width: 260);
              $C.@HeaderSearch #EditorInput {}
            }

            $C.@TextButton #AddEditor {
              Text: "Add";
              Anchor: (Width: 90, Height: 32, Left: 8);
            }

          $C.@TextButton #RemoveEditor {
            Text: "Remove";
            Anchor: (Width: 160, Height: 32, Left: 8);
          }
          }

          Label #EditorsList {
            Anchor: (Height: 22, Bottom: 12);
            Style: (FontSize: 12, TextColor: #888888);
            Text: "Editors: none";
          }

          Group #ChestRow {
            Anchor: (Height: 40, Bottom: 6);
            LayoutMode: Left;

            Label #LinkedChestsLabel {
              Anchor: (Width: 180);
              Style: (FontSize: 14, TextColor: #aaaaaa);
              Text: "Linked chests: 0";
            }

            Label #LinkedChestsCount {
              Anchor: (Width: 1, Height: 1);
              Visible: false;
              Text: "0";
            }

          $C.@TextButton #LinkChest {
            Text: "Link";
            Anchor: (Width: 130, Height: 32, Left: 8);
          }

          $C.@TextButton #UnlinkChest {
            Text: "Unlink";
            Anchor: (Width: 150, Height: 32, Left: 8);
          }

          $C.@TextButton #ClearChests {
            Text: "Clear";
            Anchor: (Width: 130, Height: 32, Left: 8);
          }
          }

          Label {
            Anchor: (Height: 20);
            Style: (FontSize: 11, TextColor: #777777);
            Text: "Look at a chest and click Link/Unlink.";
          }
        }
      }

      Group #PreviewTabContent {
        FlexWeight: 1;
        LayoutMode: Top;
        Visible: false;

        Group #PreviewHeader {
          Anchor: (Height: 50, Bottom: 5);
          LayoutMode: Top;

          Label {
            Anchor: (Bottom: 5);
            Style: (FontSize: 14, TextColor: #888888);
            Text: "Preview:";
          }

          Group {
            LayoutMode: Left;

            Label #PreviewShopName {
              FlexWeight: 1;
              Style: (FontSize: 18, TextColor: #93844c, RenderBold: true);
              Text: "Shop";
            }

            Label #PreviewClosedLabel {
              Anchor: (Width: 100);
              Style: (FontSize: 14, TextColor: #ff6666, RenderBold: true);
              Text: "[CLOSED]";
              Visible: false;
            }
          }
        }

        Group {
          Anchor: (Height: 1, Bottom: 10);
          Background: (Color: #93844c(0.4));
        }

        Group #PreviewTradeSection {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          Label #PreviewNoTradesLabel {
            Anchor: (Height: 60);
            Style: (FontSize: 15, TextColor: #666666, HorizontalAlignment: Center);
            Text: "This shop has no trades available";
            Visible: false;
          }

          Group #PreviewTradeCards {
            LayoutMode: Top;
            Padding: (Right: 10);
          }
        }
      }
    }
  }
}

$C.@BackButton {}

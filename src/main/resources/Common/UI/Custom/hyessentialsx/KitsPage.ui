$C = "../Common.ui";

$C.@PageOverlay {
  $C.@Container {
    @CloseButton = true;
    Anchor: (Width: 600, Height: 520);

    #Title {
      Group {
        $C.@Title {
          @Text = "Kits";
        }
      }

      $C.@HeaderSearch #SearchBar {}
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 15, Right: 15);
      Group #KitCountRow {
        Anchor: (Height: 22, Bottom: 8);
        LayoutMode: Left;

        Label #KitCount {
          Text: "0 Kits";
          Style: (FontSize: 12, TextColor: #888888);
        }
      }

      Group #KitListContainer {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        FlexWeight: 1;

        Group #KitList {
          LayoutMode: Top;
        }
      }
    }
  }
}

$C.@BackButton {}


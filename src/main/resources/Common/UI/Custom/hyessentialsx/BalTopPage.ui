$C = "../Common.ui";

$C.@PageOverlay {
  $C.@Container {
    @CloseButton = true;
    Anchor: (Width: 520, Height: 420);

    #Title {
      $C.@Title {
        @Text = "Balance Top";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 15, Right: 15);

      Group #HeaderRow {
        Anchor: (Height: 24, Bottom: 10);
        LayoutMode: Left;

        Label #EntryCount {
          Text: "0 Players";
          Style: (FontSize: 12, TextColor: #888888);
        }
      }

      Group #EntryListContainer {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        FlexWeight: 1;

        Group #EntryList {
          LayoutMode: Top;
        }
      }
    }
  }
}

$C.@BackButton {}

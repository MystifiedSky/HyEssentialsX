$C = "../Common.ui";

@CustomLabelStyle = LabelStyle(
  FontSize: 12,
  TextColor: #bfcdd5,
  RenderBold: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

@CustomStyle = TextButtonStyle(
  Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @CustomLabelStyle),
  Hovered: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @CustomLabelStyle),
  Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @CustomLabelStyle),
  Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: @CustomLabelStyle),
  Sounds: $C.@ButtonSounds,
);

Group #HomeRow {
  LayoutMode: Left;
  Background: (Color: #181818(0.82));
  OutlineColor: #3a3425;
  OutlineSize: 1;
  Padding: (Top: 8, Bottom: 8, Left: 12, Right: 12);
  Anchor: (Bottom: 8, Height: 58);

  Group #Info {
    LayoutMode: Top;
    FlexWeight: 1;
    Padding: (Top: 3);

    Label #HomeName {
      Style: (FontSize: 14, RenderBold: true, TextColor: #ffffff);
    }

    Label #HomeCoords {
      Style: (FontSize: 10, TextColor: #a8abb2);
      Anchor: (Top: 3);
    }
  }

  Group #Actions {
    LayoutMode: Left;
    Anchor: (Width: 76);

    $C.@TextButton #TeleportBtn {
      Anchor: (Height: 28, Width: 70, Vertical: 0);
      Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
      Text: "TP";
      Style: @CustomStyle;
    }
  }
}

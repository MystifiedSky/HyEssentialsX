$C = "../Common.ui";

Group {
  Anchor: (Height: 104, Bottom: 10);
  Padding: 10;
  Background: (Color: #181818(0.82));
  OutlineColor: #3a3425;
  OutlineSize: 1;
  LayoutMode: Left;

  Group #IconBox {
    Anchor: (Width: 84, Right: 12);
    LayoutMode: CenterMiddle;
    Background: (Color: #111417(0.9));

    Group {
      Anchor: (Width: 64, Height: 64);
      Background: (Color: #26221a(0.92));

      ItemIcon #ItemIcon {
        Anchor: (Width: 52, Height: 52, Left: 6, Top: 6);
      }
    }
  }

  Group #TextColumn {
    FlexWeight: 1;
    LayoutMode: Top;
    Padding: (Top: 4, Bottom: 4);

    Label #ItemName {
      Anchor: (Height: 26, Bottom: 4);
      Style: (FontSize: 17, TextColor: #f5f3e8, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 11);
      Text: "";
    }

    Label #Seller {
      Anchor: (Height: 20, Bottom: 4);
      Style: (FontSize: 12, TextColor: #a8abb2, VerticalAlignment: Center);
      Text: "";
    }

    Label #Time {
      Anchor: (Height: 20);
      Style: (FontSize: 12, TextColor: #d5c77e, VerticalAlignment: Center);
      Text: "";
    }
  }

  Group #PriceBox {
    Anchor: (Width: 150, Vertical: 0, Right: 12);
    LayoutMode: CenterMiddle;

    Label #Price {
      Anchor: (Width: 140, Height: 34);
      Background: (Color: #14211b(0.9));
      Style: (FontSize: 14, TextColor: #64f0b7, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
      Text: "$0";
    }
  }

  Group #ActionColumn {
    Anchor: (Width: 116, Vertical: 0);
    LayoutMode: CenterMiddle;

    Label #StatusLabel {
      Anchor: (Width: 110, Height: 34);
      Background: (Color: #111417(0.9));
      Style: (FontSize: 11, TextColor: #aaaaaa, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true, LetterSpacing: 1, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
      Text: "";
      Visible: false;
    }

    $C.@TextButton #BuyButton {
      Anchor: (Width: 110, Height: 34);
      Text: "Buy";
    }

    $C.@TextButton #CancelButton {
      Anchor: (Width: 110, Height: 34);
      Text: "Cancel";
      Visible: false;
    }

    $C.@TextButton #ClaimButton {
      Anchor: (Width: 110, Height: 34);
      Text: "Claim";
      Visible: false;
    }
  }
}

$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    @CloseButton = true;
    Anchor: (Width: 900, Height: 640);

    #Title {
      Group {
        $C.@Title { @Text = ""; }

        Label {
          Anchor: (Full: 0);
          Style: (FontSize: 24, TextColor: #f5f7ff, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "Warps";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Horizontal: 14, Top: 2, Bottom: 14);

      Group #HeaderRow {
        Anchor: (Horizontal: 0, Height: 66, Bottom: 10);
        LayoutMode: Left;
        Padding: (Left: 14, Right: 14, Top: 8, Bottom: 8);
        Background: (Color: #191714(0.92));
        OutlineColor: #7d6b3a;
        OutlineSize: 1;

        Group {
          FlexWeight: 1;
          Anchor: (Height: 48);
          LayoutMode: Top;
          Padding: (Left: 12, Right: 12, Top: 5, Bottom: 5);
          Background: (Color: #141617(0.84));

          Label {
            Anchor: (Height: 14);
            Style: (FontSize: 10, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "AVAILABLE DESTINATIONS";
          }

          Label #WarpCount {
            Text: "0 Warps";
            Anchor: (Height: 24);
            Style: (FontSize: 17, TextColor: #ffd166, RenderBold: true, VerticalAlignment: Center);
          }
        }
      }

      Group #WarpControls {
        Anchor: (Height: 52, Bottom: 10);
        LayoutMode: Left;
        Padding: (Left: 12, Right: 12, Top: 7, Bottom: 7);
        Background: (Color: #141617(0.84));
        OutlineColor: #3a3425;
        OutlineSize: 1;

        $C.@TextField #WarpSearchInput {
          FlexWeight: 1;
          Anchor: (Height: 36, Right: 10, Vertical: 0);
          PlaceholderText: "Search player warps...";
        }

        $C.@SecondaryTextButton #ClearWarpSearchButton {
          Anchor: (Width: 132, Height: 36, Right: 10, Vertical: 0);
          Text: "Clear";
        }

        $C.@SecondaryTextButton #WarpSortButton {
          Anchor: (Width: 220, Height: 36, Vertical: 0);
          Text: "Sort: Popular";
        }
      }

      Group #WarpListFrame {
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
        Background: (Color: #151515(0.84));
        OutlineColor: #3a3425;
        OutlineSize: 1;

        Group #WarpListContainer {
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          FlexWeight: 1;

          Group #WarpList {
            LayoutMode: Top;
          }
        }
      }
    }
  }
}

$C.@BackButton {}

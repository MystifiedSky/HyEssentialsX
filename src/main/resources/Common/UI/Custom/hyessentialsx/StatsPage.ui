$E = "EcoCommon.ui";

Group #StatsRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  LayoutMode: Center;

  Group #StatsWindow {
    Anchor: (Width: 860, Height: 590);
    LayoutMode: Top;
    Background: (Color: #0f1726ee);
    Padding: (Top: 10, Bottom: 12, Left: 12, Right: 12);
    OutlineColor: #2f4a72;
    OutlineSize: 1;

    Group #Header {
      LayoutMode: Left;
      Anchor: (Height: 62, Bottom: 8);
      Background: (Color: #15263d);
      Padding: (Left: 12, Right: 10, Top: 6, Bottom: 6);
      OutlineColor: #355986;
      OutlineSize: 1;

      Group {
        LayoutMode: Top;
        FlexWeight: 1;

        Label #Title {
          Text: "Player Statistics";
          Style: (FontSize: 20, TextColor: #f2f7ff, RenderBold: true);
          Anchor: (Bottom: 2);
        }

        Label #Subtitle {
          Text: "Player";
          Style: (FontSize: 11, TextColor: #8ea9cc, Wrap: true);
          Anchor: (Left: 0, Right: 0);
        }
      }

      TextButton #CloseButton {
        Text: "X";
        Style: $E.@EcoButtonRedStyle;
        Anchor: (Width: 30, Height: 28, Vertical: 0);
      }
    }

    Group #SummaryCards {
      LayoutMode: Left;
      Anchor: (Height: 78, Bottom: 8);

      Group {
        LayoutMode: Top;
        Background: (Color: #111f34);
        FlexWeight: 1;
        Anchor: (Right: 8);
        Padding: (Top: 9, Bottom: 9, Left: 10, Right: 10);
        OutlineColor: #2f4a72;
        OutlineSize: 1;
        Label { Text: "Play Time"; Style: (FontSize: 10, TextColor: #8ba6ca); }
        Label #PlayTimeValue { Text: "0s"; Style: (FontSize: 18, TextColor: #54e39e, RenderBold: true); }
      }

      Group {
        LayoutMode: Top;
        Background: (Color: #111f34);
        FlexWeight: 1;
        Anchor: (Right: 8);
        Padding: (Top: 9, Bottom: 9, Left: 10, Right: 10);
        OutlineColor: #2f4a72;
        OutlineSize: 1;
        Label { Text: "Deaths"; Style: (FontSize: 10, TextColor: #8ba6ca); }
        Label #DeathsValue { Text: "0"; Style: (FontSize: 18, TextColor: #ff8d9a, RenderBold: true); }
      }

      Group {
        LayoutMode: Top;
        Background: (Color: #111f34);
        FlexWeight: 1;
        Anchor: (Right: 8);
        Padding: (Top: 9, Bottom: 9, Left: 10, Right: 10);
        OutlineColor: #2f4a72;
        OutlineSize: 1;
        Label { Text: "Total Kills"; Style: (FontSize: 10, TextColor: #8ba6ca); }
        Label #KillsValue { Text: "0"; Style: (FontSize: 18, TextColor: #f2be5c, RenderBold: true); }
      }

      Group {
        LayoutMode: Top;
        Background: (Color: #111f34);
        FlexWeight: 1;
        Padding: (Top: 9, Bottom: 9, Left: 10, Right: 10);
        OutlineColor: #2f4a72;
        OutlineSize: 1;
        Label { Text: "Distance"; Style: (FontSize: 10, TextColor: #8ba6ca); }
        Label #DistanceValue { Text: "0 cm"; Style: (FontSize: 18, TextColor: #8fd3ff, RenderBold: true); }
      }
    }

    Group #TabRow {
      LayoutMode: Left;
      Anchor: (Height: 34, Bottom: 8);

      TextButton #TabGeneral {
        Text: "GENERAL";
        Style: $E.@EcoButtonStyle;
        Anchor: (Width: 130, Height: 30, Vertical: 0, Right: 6);
      }
      TextButton #TabItems {
        Text: "ITEMS";
        Style: $E.@EcoButtonStyle;
        Anchor: (Width: 130, Height: 30, Vertical: 0, Right: 6);
      }
      TextButton #TabMobs {
        Text: "MOBS";
        Style: $E.@EcoButtonStyle;
        Anchor: (Width: 130, Height: 30, Vertical: 0);
      }
    }

    Group #GeneralContent {
      LayoutMode: Top;
      FlexWeight: 1;

      Group #GeneralListContainer {
        LayoutMode: TopScrolling;
        Background: (Color: #111f34);
        FlexWeight: 1;
        Padding: (Top: 8, Bottom: 8, Left: 8, Right: 8);
        OutlineColor: #2f4a72;
        OutlineSize: 1;

        Label #GeneralEmpty {
          Text: "No statistics recorded yet.";
          Style: (FontSize: 13, TextColor: #8da8cc, HorizontalAlignment: Center);
          Anchor: (Height: 28, Top: 18);
          Visible: false;
        }

        Group #GeneralList {
          LayoutMode: Top;
        }
      }
    }

    Group #ItemsContent {
      LayoutMode: Top;
      FlexWeight: 1;
      Visible: false;

      Label #ItemCount {
        Text: "0 tracked items";
        Style: (FontSize: 11, TextColor: #8da8cc);
        Anchor: (Height: 22, Bottom: 4);
      }

      Group #ItemListContainer {
        LayoutMode: TopScrolling;
        Background: (Color: #111f34);
        FlexWeight: 1;
        Padding: (Top: 8, Bottom: 8, Left: 8, Right: 8);
        OutlineColor: #2f4a72;
        OutlineSize: 1;

        Label #ItemsEmpty {
          Text: "No item statistics recorded yet.";
          Style: (FontSize: 13, TextColor: #8da8cc, HorizontalAlignment: Center);
          Anchor: (Height: 28, Top: 18);
          Visible: false;
        }

        Group #ItemList {
          LayoutMode: Top;
        }
      }
    }

    Group #MobsContent {
      LayoutMode: Top;
      FlexWeight: 1;
      Visible: false;

      Label #MobCount {
        Text: "0 tracked mobs";
        Style: (FontSize: 11, TextColor: #8da8cc);
        Anchor: (Height: 22, Bottom: 4);
      }

      Group #MobListContainer {
        LayoutMode: TopScrolling;
        Background: (Color: #111f34);
        FlexWeight: 1;
        Padding: (Top: 8, Bottom: 8, Left: 8, Right: 8);
        OutlineColor: #2f4a72;
        OutlineSize: 1;

        Label #MobsEmpty {
          Text: "No mob statistics recorded yet.";
          Style: (FontSize: 13, TextColor: #8da8cc, HorizontalAlignment: Center);
          Anchor: (Height: 28, Top: 18);
          Visible: false;
        }

        Group #MobList {
          LayoutMode: Top;
        }
      }
    }
  }
}
